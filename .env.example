# Copy this file to .env for local pipeline runs.
# The repository root .env is loaded by pipeline/discovery/step2_community_scan.py.

# Optional but recommended: raises GitHub API limits for repo discovery.
GITHUB_TOKEN=ghp_xxx

# Optional but strongly recommended: Reddit OAuth for stable community scanning.
# Create an app at https://www.reddit.com/prefs/apps and use the app-only credentials below.
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Recommended format: <app_name>/<version> by <reddit_username>
REDDIT_USER_AGENT=DailyMicroSaaS/0.1 by your_reddit_username

# Optional public email subscription URL used by Astro subscribe pages/components.
# Local builds can read it from .env; GitHub deploy builds should set the same value in repo variable PUBLIC_EMAIL_SUBSCRIBE_URL.
PUBLIC_EMAIL_SUBSCRIBE_URL=https://example.com/newsletter
