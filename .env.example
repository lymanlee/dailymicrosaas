# SiliconFlow API Configuration
SILICONFLOW_API_KEY=your_api_key_here
SILICONFLOW_MODEL=Qwen/Qwen2.5-32B-Instruct

# Base URL: use api.siliconflow.com for international, api.siliconflow.cn for China
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1

# Optional: Use 72B model for better quality (higher cost)
# SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# Cache Configuration
CACHE_TTL_DAYS=7
CACHE_DIR=./cache/competitor_profiles

# Fetch Configuration
FETCH_DELAY_MIN=2
FETCH_DELAY_MAX=5
FETCH_TIMEOUT=30
