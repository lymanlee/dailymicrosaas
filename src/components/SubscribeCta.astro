---
import { type Lang, withLangPath } from '../lib/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const emailSubscribeUrl = import.meta.env.PUBLIC_EMAIL_SUBSCRIBE_URL?.trim();
const rssUrl = lang === 'zh' ? '/rss-zh.xml' : '/rss.xml';

const copy = {
  kicker: {
    en: 'Subscription',
    zh: '订阅入口',
  },
  title: {
    en: 'Get new ideas without checking manually',
    zh: '不想手动刷站点，就直接订阅',
  },
  body: {
    en: emailSubscribeUrl
      ? 'RSS is live, and email updates are available. Pick whichever channel fits your workflow.'
      : 'RSS is live now. Email updates are reserved as the next step once the newsletter channel is switched on.',
    zh: emailSubscribeUrl
      ? 'RSS 已可用，邮件更新也已开放。按你自己的工作流选一个就行。'
      : 'RSS 现在就能订阅；邮件更新入口已经预留，下一步会在邮件通道接通后直接打开。',
  },
  primary: {
    en: 'Open subscription options',
    zh: '查看订阅方式',
  },
  rss: {
    en: 'Open RSS feed',
    zh: '打开 RSS',
  },
  emailReady: {
    en: 'Email updates are available now.',
    zh: '邮件更新现已可用。',
  },
  emailSoon: {
    en: 'Email updates are the next thing to turn on.',
    zh: '邮件更新会是下一步优先补齐的入口。',
  },
} as const;
---

<section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm lg:p-7">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-2xl">
      <span
        data-l10n-en={copy.kicker.en}
        data-l10n-zh={copy.kicker.zh}
        class="section-kicker"
      >
        {lang === 'zh' ? copy.kicker.zh : copy.kicker.en}
      </span>
      <h2
        data-l10n-en={copy.title.en}
        data-l10n-zh={copy.title.zh}
        class="mt-3 text-3xl font-black tracking-tight text-slate-950"
      >
        {lang === 'zh' ? copy.title.zh : copy.title.en}
      </h2>
      <p
        data-l10n-en={copy.body.en}
        data-l10n-zh={copy.body.zh}
        class="mt-3 text-base leading-7 text-slate-600"
      >
        {lang === 'zh' ? copy.body.zh : copy.body.en}
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row">
      <a
        href={withLangPath('/subscribe', lang)}
        data-l10n-en={copy.primary.en}
        data-l10n-zh={copy.primary.zh}
        class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary"
      >
        {lang === 'zh' ? copy.primary.zh : copy.primary.en}
      </a>
      <a
        href={rssUrl}
        data-l10n-en={copy.rss.en}
        data-l10n-zh={copy.rss.zh}
        class="inline-flex items-center justify-center rounded-full border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary"
      >
        {lang === 'zh' ? copy.rss.zh : copy.rss.en}
      </a>
    </div>
  </div>

  <p
    data-l10n-en={emailSubscribeUrl ? copy.emailReady.en : copy.emailSoon.en}
    data-l10n-zh={emailSubscribeUrl ? copy.emailReady.zh : copy.emailSoon.zh}
    class="mt-4 text-sm text-slate-500"
  >
    {lang === 'zh'
      ? (emailSubscribeUrl ? copy.emailReady.zh : copy.emailSoon.zh)
      : (emailSubscribeUrl ? copy.emailReady.en : copy.emailSoon.en)}
  </p>
</section>
