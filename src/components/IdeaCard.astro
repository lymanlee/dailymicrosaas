---
interface Props {
  title: string;
  slug: string;
  date: string;
  category: string;
  difficulty: string;
  description: string;
  status?: string;
  featured?: boolean;
}

const { title, slug, date, category, difficulty, description, status, featured = false } = Astro.props;

const difficultyMeta: Record<string, { labelKey: string; label: string; classes: string }> = {
  Easy: { labelKey: 'card.difficulty.easy', label: 'Quick to validate', classes: 'bg-emerald-50 text-emerald-700 ring-emerald-200' },
  Medium: { labelKey: 'card.difficulty.medium', label: 'Needs some polish', classes: 'bg-amber-50 text-amber-700 ring-amber-200' },
  Hard: { labelKey: 'card.difficulty.hard', label: 'Execution-heavy', classes: 'bg-rose-50 text-rose-700 ring-rose-200' },
};

const categoryColors: Record<string, string> = {
  'AI 工具': 'bg-violet-50 text-violet-700 ring-violet-200',
  '文档处理': 'bg-sky-50 text-sky-700 ring-sky-200',
  '图像处理': 'bg-pink-50 text-pink-700 ring-pink-200',
  '视频处理': 'bg-orange-50 text-orange-700 ring-orange-200',
  '效率工具': 'bg-teal-50 text-teal-700 ring-teal-200',
  '开发者工具': 'bg-slate-100 text-slate-700 ring-slate-200',
  // English equivalents
  'AI Tools': 'bg-violet-50 text-violet-700 ring-violet-200',
  'Document Processing': 'bg-sky-50 text-sky-700 ring-sky-200',
  'Image Processing': 'bg-pink-50 text-pink-700 ring-pink-200',
  'Video Processing': 'bg-orange-50 text-orange-700 ring-orange-200',
  'Productivity': 'bg-teal-50 text-teal-700 ring-teal-200',
  'Dev Tools': 'bg-slate-100 text-slate-700 ring-slate-200',
};

const href = `/ideas/${slug}`;
const difficultyInfo = difficultyMeta[difficulty] || {
  labelKey: 'card.difficulty.easy',
  label: difficulty,
  classes: 'bg-slate-100 text-slate-700 ring-slate-200',
};
---

<article class={`group relative h-full overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-soft ${featured ? 'p-8 lg:p-10' : 'p-6'}`}>
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-primary via-sky-400 to-secondary"></div>
  <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
      <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset ${categoryColors[category] || 'bg-slate-100 text-slate-700 ring-slate-200'}`}>
        {category}
      </span>
      <span data-i18n={difficultyInfo.labelKey} class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset ${difficultyInfo.classes}`}>
        {difficultyInfo.label}
      </span>
      {status === 'New' && (
        <span data-i18n="card.status.new" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-200">
          New today
        </span>
      )}
    </div>
    <time class="text-sm font-medium text-slate-400">{date}</time>
  </div>

  <div class="space-y-4">
    <h2 class={`font-bold tracking-tight text-slate-950 transition group-hover:text-primary ${featured ? 'text-3xl sm:text-4xl leading-tight' : 'text-2xl leading-snug'}`}>
      <a href={href}>{title}</a>
    </h2>

    <p class={`leading-8 text-slate-600 ${featured ? 'max-w-3xl text-lg' : 'text-base'}`}>
      {description}
    </p>
  </div>

  <div class={`mt-8 flex items-center justify-between gap-4 ${featured ? 'flex-col items-start sm:flex-row sm:items-center' : ''}`}>
    <p data-i18n="card.teaser" class="text-sm text-slate-500">Demand signals, competitive context, monetisation options, and the fastest path to launch — all broken down for you.</p>
    <a
      href={href}
      data-i18n="card.cta"
      class="inline-flex items-center gap-2 rounded-full bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-primary"
    >
      Read breakdown
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
