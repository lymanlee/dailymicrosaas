---
import { ui, type Lang, withLangPath } from '../lib/i18n';
import { getCategoryInfo, getLocalizedText, type LocalizedText } from '../lib/idea';

interface Props {
  title: LocalizedText;
  slug: string;
  date: string;
  category: string;
  difficulty: string;
  description: LocalizedText;
  status?: string;
  featured?: boolean;
  lang?: Lang;
}

const {
  title,
  slug,
  date,
  category,
  difficulty,
  description,
  status,
  featured = false,
  lang = 'en',
} = Astro.props;

const t = ui[lang] ?? ui.en;
const localizedTitleEn = getLocalizedText(title, 'en', 'Untitled');
const localizedTitleZh = getLocalizedText(title, 'zh', localizedTitleEn);
const localizedDescriptionEn = getLocalizedText(description, 'en', '');
const localizedDescriptionZh = getLocalizedText(description, 'zh', localizedDescriptionEn);

const difficultyMeta: Record<string, { labelKey: string; label: string; classes: string }> = {
  Easy: { labelKey: 'card.difficulty.easy', label: 'Quick to validate', classes: 'bg-emerald-50 text-emerald-700 ring-emerald-200' },
  Medium: { labelKey: 'card.difficulty.medium', label: 'Needs some polish', classes: 'bg-amber-50 text-amber-700 ring-amber-200' },
  Hard: { labelKey: 'card.difficulty.hard', label: 'Execution-heavy', classes: 'bg-rose-50 text-rose-700 ring-rose-200' },
};

const href = withLangPath(`/ideas/${slug}`, lang);
const categoryInfo = getCategoryInfo(category);
const difficultyInfo = difficultyMeta[difficulty] || {
  labelKey: 'card.difficulty.easy',
  label: difficulty,
  classes: 'bg-slate-100 text-slate-700 ring-slate-200',
};
---

<article class={`group relative h-full overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-soft ${featured ? 'p-8 lg:p-10' : 'p-6'}`}>
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-primary via-sky-400 to-secondary"></div>
  <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
      <span
        data-l10n-en={categoryInfo.en}
        data-l10n-zh={categoryInfo.zh}
        class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset ${categoryInfo.classes}`}
      >
        {lang === 'zh' ? categoryInfo.zh : categoryInfo.en}
      </span>
      <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset ${difficultyInfo.classes}`}>
        {t[difficultyInfo.labelKey]}
      </span>
      {status === 'New' && (
        <span class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-200">
          {t['card.status.new']}
        </span>
      )}
    </div>
    <time class="text-sm font-medium text-slate-400">{date}</time>
  </div>

  <div class="space-y-4">
    <h2 class={`font-bold tracking-tight text-slate-950 transition group-hover:text-primary ${featured ? 'text-3xl sm:text-4xl leading-tight' : 'text-2xl leading-snug'}`}>
      <a
        href={href}
        data-l10n-en={localizedTitleEn}
        data-l10n-zh={localizedTitleZh}
      >
        {lang === 'zh' ? localizedTitleZh : localizedTitleEn}
      </a>
    </h2>

    <p
      data-l10n-en={localizedDescriptionEn}
      data-l10n-zh={localizedDescriptionZh}
      class={`leading-8 text-slate-600 ${featured ? 'max-w-3xl text-lg' : 'text-base'}`}
    >
      {lang === 'zh' ? localizedDescriptionZh : localizedDescriptionEn}
    </p>
  </div>

  <div class={`mt-8 flex items-center justify-between gap-4 ${featured ? 'flex-col items-start sm:flex-row sm:items-center' : ''}`}>
    <p class="text-sm text-slate-500">{t['card.teaser']}</p>
    <a
      href={href}
      class="inline-flex items-center gap-2 rounded-full bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-primary"
    >
      {t['card.cta']}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
