---
interface Props {
  title: string;
  slug: string;
  date: string;
  category: string;
  difficulty: string;
  description: string;
  status?: string;
}

const { title, slug, date, category, difficulty, description, status } = Astro.props;

const difficultyColors: Record<string, string> = {
  'Easy': 'bg-green-100 text-green-800',
  'Medium': 'bg-yellow-100 text-yellow-800',
  'Hard': 'bg-red-100 text-red-800',
};

const categoryColors: Record<string, string> = {
  'AI 工具': 'bg-purple-100 text-purple-800',
  '文档处理': 'bg-blue-100 text-blue-800',
  '图像处理': 'bg-pink-100 text-pink-800',
  '视频处理': 'bg-orange-100 text-orange-800',
  '效率工具': 'bg-teal-100 text-teal-800',
  '开发者工具': 'bg-gray-100 text-gray-800',
};
---

<article class="bg-white rounded-lg shadow-sm border p-6 hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="flex items-center gap-2">
      <span class={`text-xs px-2 py-1 rounded-full font-medium ${categoryColors[category] || 'bg-gray-100 text-gray-800'}`}>
        {category}
      </span>
      <span class={`text-xs px-2 py-1 rounded-full font-medium ${difficultyColors[difficulty] || 'bg-gray-100 text-gray-800'}`}>
        {difficulty}
      </span>
      {status === 'New' && (
        <span class="text-xs px-2 py-1 rounded-full font-medium bg-red-100 text-red-800">
          New
        </span>
      )}
    </div>
    <time class="text-sm text-gray-500">{date}</time>
  </div>
  
  <h2 class="text-xl font-bold mb-2">
    <a href={`/ideas/${slug}`} class="hover:text-primary transition-colors">
      {title}
    </a>
  </h2>
  
  <p class="text-gray-600 text-sm leading-relaxed mb-4">
    {description}
  </p>
  
  <a 
    href={`/ideas/${slug}`} 
    class="inline-flex items-center text-sm text-primary hover:text-primary/80 font-medium"
  >
    查看详情 →
  </a>
</article>