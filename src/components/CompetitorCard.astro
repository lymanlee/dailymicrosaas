---
import type { Lang } from '../lib/i18n';
import type { CompetitorProfile } from '../lib/competitor';
import { getLocalizedPairText, getCompetitorUrl, formatPrice } from '../lib/competitor';

interface Props {
  competitor: CompetitorProfile;
  lang: Lang;
}

const { competitor, lang } = Astro.props;
const url = getCompetitorUrl(competitor.domain);
---

<div class="rounded-2xl border border-slate-200 bg-white p-5 transition hover:border-slate-300">
  {/* Header Row */}
  <div class="flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h3 class="text-base font-bold text-slate-900">
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-primary"
        >
          {getLocalizedPairText(competitor.name, lang)}
        </a>
      </h3>
      {competitor.pricingTiers.length > 0 && (
        <span class="text-sm text-slate-500">
          {(() => {
            const tiers = competitor.pricingTiers;
            const hasFree = tiers.some(t => t.price === 0);
            const paidPrices = tiers.map(t => t.price).filter(p => p > 0);
            
            if (paidPrices.length === 0) {
              return lang === 'zh' ? '免费' : 'Free';
            }
            
            const minPaid = Math.min(...paidPrices);
            const maxPaid = Math.max(...paidPrices);
            
            if (hasFree) {
              if (minPaid === maxPaid) {
                return `Free – $${minPaid}/mo`;
              }
              return `Free – $${maxPaid}/mo`;
            }
            
            if (minPaid === maxPaid) {
              return `$${minPaid}/mo`;
            }
            return `$${minPaid}–${maxPaid}/mo`;
          })()}
        </span>
      )}
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition hover:bg-slate-200 hover:text-slate-700"
      aria-label={`Visit ${getLocalizedPairText(competitor.name, lang)}`}
    >
      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>

  {/* Weaknesses - Inline, subtle */}
  {competitor.weaknesses.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {competitor.weaknesses.slice(0, 2).map((weakness) => (
        <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-xs text-amber-700">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <span data-l10n-en={weakness.en} data-l10n-zh={weakness.zh}>
            {getLocalizedPairText(weakness, lang)}
          </span>
        </span>
      ))}
    </div>
  )}
</div>
