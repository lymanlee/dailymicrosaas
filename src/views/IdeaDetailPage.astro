---
import Layout from '../layouts/Layout.astro';
import { ui, type Lang, withLangPath } from '../lib/i18n';
import {
  buildLocalizedExecutionSteps,
  buildLocalizedMonetizationItems,
  buildLocalizedWhyNow,
  buildSourceSignalCards,
  estimateReadingTime,
  getCategoryInfo,
  getLocalizedPairText,
  getLocalizedTextStrict,
  getSection,
  parseIdeaSections,
} from '../lib/idea';
import { parseCompetitorAnalysis } from '../lib/competitor';
import CompetitorAnalysisSection from '../components/CompetitorAnalysisSection.astro';

interface Props {
  idea: any;
  lang: Lang;
}

const { idea, lang } = Astro.props;
const t = ui[lang] ?? ui.en;
const { data: frontmatter } = idea;
const rawContent = idea.body ?? '';
const sections = parseIdeaSections(rawContent);
const readingTime = estimateReadingTime(rawContent);
const demandSection = getSection(sections, ['真实需求来源']);
const keywordsSection = getSection(sections, ['SEO 关键词']);

const keywordItems = keywordsSection?.bullets.slice(0, 5).map((item) => item.replace(/\s*\([^\)]*\)/g, '').trim()) ?? [];
const evidenceLinks = frontmatter.evidenceLinks ?? [];
const sourceSignalCards = buildSourceSignalCards(demandSection, evidenceLinks);
const convictionItems = buildLocalizedWhyNow(frontmatter, demandSection);
const monetizationItems = buildLocalizedMonetizationItems(frontmatter.category ?? '');
const executionSteps = buildLocalizedExecutionSteps(frontmatter.sourceKeyword ?? '', frontmatter.difficulty ?? 'Medium');
const competitorAnalysis = parseCompetitorAnalysis(frontmatter);
const localizedTitleEn = getLocalizedTextStrict(frontmatter.title, 'en', 'title');
const localizedTitleZh = getLocalizedTextStrict(frontmatter.title, 'zh', 'title');
const localizedDescriptionEn = getLocalizedTextStrict(frontmatter.description, 'en', 'description');
const localizedDescriptionZh = getLocalizedTextStrict(frontmatter.description, 'zh', 'description');
const bestWedgeEn = getLocalizedTextStrict(frontmatter.bestWedge, 'en', 'bestWedge');
const bestWedgeZh = getLocalizedTextStrict(frontmatter.bestWedge, 'zh', 'bestWedge');
const dataWindowEn = getLocalizedTextStrict(frontmatter.dataWindow, 'en', 'dataWindow');
const dataWindowZh = getLocalizedTextStrict(frontmatter.dataWindow, 'zh', 'dataWindow');
const buildWindowEn = getLocalizedTextStrict(frontmatter.buildWindow, 'en', 'buildWindow');
const buildWindowZh = getLocalizedTextStrict(frontmatter.buildWindow, 'zh', 'buildWindow');
const painClusters = (frontmatter.painClusters ?? []).map((item, index) => ({
  en: getLocalizedTextStrict(item, 'en', `painClusters[${index}]`),
  zh: getLocalizedTextStrict(item, 'zh', `painClusters[${index}]`),
}));
const competitorGaps = (frontmatter.competitorGaps ?? []).map((item, index) => ({
  en: getLocalizedTextStrict(item, 'en', `competitorGaps[${index}]`),
  zh: getLocalizedTextStrict(item, 'zh', `competitorGaps[${index}]`),
}));
const risks = (frontmatter.risks ?? []).map((item, index) => ({
  risk: {
    en: getLocalizedTextStrict(item.risk, 'en', `risks[${index}].risk`),
    zh: getLocalizedTextStrict(item.risk, 'zh', `risks[${index}].risk`),
  },
  mitigation: {
    en: getLocalizedTextStrict(item.mitigation, 'en', `risks[${index}].mitigation`),
    zh: getLocalizedTextStrict(item.mitigation, 'zh', `risks[${index}].mitigation`),
  },
}));
const unsuitableFor = (frontmatter.unsuitableFor ?? []).map((item, index) => ({
  en: getLocalizedTextStrict(item, 'en', `unsuitableFor[${index}]`),
  zh: getLocalizedTextStrict(item, 'zh', `unsuitableFor[${index}]`),
}));
const siteUrl = (Astro.site?.toString() || 'https://dailymicrosaas.pages.dev').replace(/\/$/, '');
const articleUrl = new URL(withLangPath(`/ideas/${idea.slug}`, lang), `${siteUrl}/`).toString();
const pageTitleMap = {
  en: `${localizedTitleEn} - Daily Micro SaaS`,
  zh: `${localizedTitleZh}｜Daily Micro SaaS 拆解`,
};
const pageDescriptionMap = {
  en: localizedDescriptionEn,
  zh: localizedDescriptionZh || `围绕 ${localizedTitleZh} 的 Micro SaaS 机会拆解：需求信号、竞争判断、变现方式和最快落地路径。`,
};
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: lang === 'zh' ? localizedTitleZh : localizedTitleEn,
  description: pageDescriptionMap[lang],
  datePublished: frontmatter.date,
  dateModified: frontmatter.dataDate ?? frontmatter.date,
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en',
  articleSection: lang === 'zh' ? getCategoryInfo(frontmatter.category).zh : getCategoryInfo(frontmatter.category).en,
  mainEntityOfPage: articleUrl,
  author: {
    '@type': 'Organization',
    name: 'Daily Micro SaaS',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Daily Micro SaaS',
  },
  image: [new URL('/social-card.svg', `${siteUrl}/`).toString()],
  keywords: keywordItems.join(', '),
};

const difficultyMeta: Record<string, { labelKey: string; label: string; classes: string }> = {
  Easy: { labelKey: 'card.difficulty.easy', label: 'Quick to validate', classes: 'bg-emerald-50 text-emerald-700 ring-emerald-200' },
  Medium: { labelKey: 'card.difficulty.medium', label: 'Needs some polish', classes: 'bg-amber-50 text-amber-700 ring-amber-200' },
  Hard: { labelKey: 'card.difficulty.hard', label: 'Execution-heavy', classes: 'bg-rose-50 text-rose-700 ring-rose-200' },
};

const difficultyInfo = difficultyMeta[frontmatter.difficulty] ?? { labelKey: 'card.difficulty.easy', label: frontmatter.difficulty, classes: 'bg-slate-100 text-slate-700 ring-slate-200' };
const categoryInfo = getCategoryInfo(frontmatter.category);

const verdictConfig: Record<string, { labelKey: string; emoji: string; bg: string; text: string; ring: string; bar: string }> = {
  'Worth Building': {
    labelKey: 'detail.verdict.worth_building',
    emoji: '✅',
    bg: 'bg-emerald-50',
    text: 'text-emerald-800',
    ring: 'ring-emerald-200',
    bar: 'bg-emerald-500',
  },
  'Watch': {
    labelKey: 'detail.verdict.watch',
    emoji: '👀',
    bg: 'bg-amber-50',
    text: 'text-amber-800',
    ring: 'ring-amber-200',
    bar: 'bg-amber-400',
  },
  'Skip': {
    labelKey: 'detail.verdict.skip',
    emoji: '⏭️',
    bg: 'bg-slate-50',
    text: 'text-slate-600',
    ring: 'ring-slate-200',
    bar: 'bg-slate-400',
  },
};
const verdict = frontmatter.verdict ?? (
  frontmatter.sourceGrade === 'worth_it' ? 'Worth Building' :
  frontmatter.sourceGrade === 'watch' ? 'Watch' : 'Skip'
);
const verdictInfo = verdictConfig[verdict] ?? verdictConfig['Watch'];

const confidenceConfig: Record<string, { labelKey: string; dots: number; color: string }> = {
  'High': { labelKey: 'detail.confidence.high', dots: 3, color: 'bg-emerald-500' },
  'Medium': { labelKey: 'detail.confidence.medium', dots: 2, color: 'bg-amber-400' },
  'Low': { labelKey: 'detail.confidence.low', dots: 1, color: 'bg-slate-400' },
};
const confidence = frontmatter.confidence ?? 'Medium';
const confidenceInfo = confidenceConfig[confidence] ?? confidenceConfig['Medium'];

const score = frontmatter.sourceScore ?? 0;
const scorePercent = Math.min(Math.round(score), 100);

// Opportunity Score with TAM
const opportunityScore = {
  demand: 4,
  competition: 3,
  barrier: 2,
  monetization: 5,
};

// TAM from frontmatter (market size in absolute value, e.g., "$1.2B" or "12亿美元")
const tamValue = frontmatter.tam ?? frontmatter.marketSize ?? null;

// Key Metrics
const trendSeries = Array.isArray(frontmatter.trendSeries)
  ? frontmatter.trendSeries.filter((item) => typeof item?.date === 'string' && typeof item?.value === 'number')
  : [];

// Chart dimensions with fixed aspect ratio (similar to redesign)
const dataCount = trendSeries.length;
const pointSpacing = 20; // horizontal spacing between points
const paddingX = 10;
const viewBoxWidth = dataCount > 1 ? (dataCount - 1) * pointSpacing + paddingX * 2 : 100;
const viewBoxHeight = 100;
const chartWidth = viewBoxWidth;
const chartHeight = viewBoxHeight;

const trendPeak = trendSeries.length ? Math.max(...trendSeries.map((item) => item.value)) : 0;
const trendFloor = trendSeries.length ? Math.min(...trendSeries.map((item) => item.value)) : 0;

// ECharts-style Y-axis: use exact min/max as bounds, fill entire chart height
// Add small padding to avoid points touching edges
const paddingY = 5; // 5% padding top and bottom
const trendRange = trendPeak - trendFloor || 1; // avoid division by zero

// Calculate points with full-range Y-axis scaling (ECharts style)
const trendPoints = trendSeries.map((item, index) => {
  const x = dataCount <= 1 ? viewBoxWidth / 2 : index * pointSpacing + paddingX;
  // Map value to Y coordinate: min value at bottom (near viewBoxHeight), max at top (near 0)
  const normalizedValue = (item.value - trendFloor) / trendRange; // 0 to 1
  const y = viewBoxHeight - paddingY - normalizedValue * (viewBoxHeight - paddingY * 2);
  return { x, y, value: item.value, date: item.date };
});

const trendPolylinePoints = trendPoints.map(p => `${p.x.toFixed(2)},${p.y.toFixed(2)}`).join(' ');
const trendAreaPoints = trendPolylinePoints 
  ? `${trendPolylinePoints} ${viewBoxWidth - paddingX},${viewBoxHeight} ${paddingX},${viewBoxHeight}` 
  : '';

const trendRecentWindow = trendSeries.slice(-7);
const trendRecentAvg = trendRecentWindow.length
  ? Math.round((trendRecentWindow.reduce((sum, item) => sum + item.value, 0) / trendRecentWindow.length) * 10) / 10
  : 0;
const trendChange = trendSeries.length > 1 
  ? Math.round(((trendSeries[trendSeries.length - 1].value - trendSeries[0].value) / trendSeries[0].value) * 100)
  : 0;

// Competitor count from analysis
const competitorCount = competitorAnalysis?.topCompetitors?.length ?? competitorGaps.length;
---

<Layout
  title={pageTitleMap[lang]}
  description={pageDescriptionMap[lang]}
  type="article"
  structuredData={structuredData}
  lang={lang}
  i18nTitle={pageTitleMap}
  i18nDescription={pageDescriptionMap}
>
  <div class="mb-6">
    <a href={withLangPath('/', lang)} class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 transition hover:text-primary">
      {t['detail.back']}
    </a>
  </div>

  <article class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-start">
    <!-- Main Column -->
    <div class="space-y-6">
      <!-- Hero Section -->
      <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="flex flex-wrap items-center gap-2 border-b border-slate-100 px-6 py-4">
          <span
            data-l10n-en={categoryInfo.en}
            data-l10n-zh={categoryInfo.zh}
            class={`inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 ring-inset ${categoryInfo.classes}`}
          >
            {lang === 'zh' ? categoryInfo.zh : categoryInfo.en}
          </span>
          <span class={`inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 ring-inset ${difficultyInfo.classes}`}>
            {t[difficultyInfo.labelKey]}
          </span>
          {frontmatter.status === 'New' && (
            <span class="inline-flex rounded-full bg-rose-50 px-2.5 py-0.5 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-200">
              {t['detail.status.new']}
            </span>
          )}
          <time class="ml-auto text-xs font-medium text-slate-400">{frontmatter.date}</time>
        </div>

        <div class="px-6 pt-6 pb-5">
          <h1
            data-l10n-en={localizedTitleEn}
            data-l10n-zh={localizedTitleZh}
            class="max-w-4xl text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl"
          >
            {lang === 'zh' ? localizedTitleZh : localizedTitleEn}
          </h1>
          <p
            data-l10n-en={localizedDescriptionEn}
            data-l10n-zh={localizedDescriptionZh}
            class="mt-3 max-w-3xl text-base leading-7 text-slate-600"
          >
            {lang === 'zh' ? localizedDescriptionZh : localizedDescriptionEn}
          </p>

          <!-- Opportunity Score -->
          <div class="mt-5 p-5 bg-slate-50 rounded-xl border border-slate-100">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-slate-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                <h3 class="font-semibold text-slate-900">{t['detail.opportunity_score']}</h3>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-xl font-bold text-slate-900">{score.toFixed(0)}</span>
                <span class="text-xs text-slate-400">/100</span>
              </div>
            </div>
            
            <!-- Verdict Badge -->
            <div class="flex items-center gap-2 mb-4">
              <span>{verdictInfo.emoji}</span>
              <span class={`inline-flex rounded-full px-2.5 py-0.5 text-xs font-bold ${verdictInfo.bg} ${verdictInfo.text} ring-1 ring-inset ${verdictInfo.ring}`}>
                {t[verdictInfo.labelKey]}
              </span>
            </div>

            <!-- Score Bars -->
            <div class="grid grid-cols-2 gap-x-4 gap-y-3">
              <div class="space-y-1">
                <div class="flex justify-between text-xs">
                  <span class="text-slate-500">{t['detail.opportunity_score.demand']}</span>
                  <span class="font-medium text-slate-700">{opportunityScore.demand}/5</span>
                </div>
                <div class="h-1.5 bg-slate-200 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald-500 rounded-full" style={`width: ${(opportunityScore.demand / 5) * 100}%`}></div>
                </div>
              </div>
              <div class="space-y-1">
                <div class="flex justify-between text-xs">
                  <span class="text-slate-500">{t['detail.opportunity_score.competition']}</span>
                  <span class="font-medium text-slate-700">{opportunityScore.competition}/5</span>
                </div>
                <div class="h-1.5 bg-slate-200 rounded-full overflow-hidden">
                  <div class="h-full bg-amber-500 rounded-full" style={`width: ${(opportunityScore.competition / 5) * 100}%`}></div>
                </div>
              </div>
              <div class="space-y-1">
                <div class="flex justify-between text-xs">
                  <span class="text-slate-500">{t['detail.opportunity_score.barrier']}</span>
                  <span class="font-medium text-slate-700">{opportunityScore.barrier}/5</span>
                </div>
                <div class="h-1.5 bg-slate-200 rounded-full overflow-hidden">
                  <div class="h-full bg-sky-500 rounded-full" style={`width: ${(opportunityScore.barrier / 5) * 100}%`}></div>
                </div>
              </div>
              <div class="space-y-1">
                <div class="flex justify-between text-xs">
                  <span class="text-slate-500">{t['detail.opportunity_score.monetization']}</span>
                  <span class="font-medium text-slate-700">{opportunityScore.monetization}/5</span>
                </div>
                <div class="h-1.5 bg-slate-200 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald-500 rounded-full" style={`width: ${(opportunityScore.monetization / 5) * 100}%`}></div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </section>

      <!-- Evidence Section -->
      {trendSeries.length > 1 && (
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <svg class="w-4 h-4 text-sky-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 3v18h18"/>
              <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>
            </svg>
            {t['detail.evidence.title']}
          </h2>
          
          <!-- Signal Cards -->
          <div class="grid grid-cols-3 gap-3 mt-4">
            <div class="rounded-xl border border-sky-100 bg-sky-50/50 p-3">
              <div class="flex items-center gap-1.5 text-sky-700">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                  <polyline points="17 6 23 6 23 12"/>
                </svg>
                <span class="text-xs font-medium">{t['detail.evidence.signal.search']}</span>
              </div>
              <p class="mt-1.5 text-lg font-bold text-slate-900">
                {trendChange > 0 ? '+' : ''}{trendChange}%
              </p>
            </div>
            <div class="rounded-xl border border-orange-100 bg-orange-50/50 p-3">
              <div class="flex items-center gap-1.5 text-orange-700">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span class="text-xs font-medium">{t['detail.evidence.signal.community']}</span>
              </div>
              <p class="mt-1.5 text-lg font-bold text-slate-900">High</p>
            </div>
            <div class="rounded-xl border border-violet-100 bg-violet-50/50 p-3">
              <div class="flex items-center gap-1.5 text-violet-700">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                <span class="text-xs font-medium">{t['detail.evidence.signal.gap']}</span>
              </div>
              <p class="mt-1.5 text-lg font-bold text-slate-900">{competitorGaps.length || 3}</p>
            </div>
          </div>

          <!-- Trend Chart -->
          <div class="mt-4 rounded-xl border border-slate-200 bg-white p-4">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-medium text-slate-500">{t['detail.trend.title']}</span>
              <span class={`text-xs font-semibold ${trendChange >= 0 ? 'text-emerald-600' : 'text-rose-600'}`}>
                {trendChange >= 0 ? '↑' : '↓'} {Math.abs(trendChange)}%
              </span>
            </div>
            <div class="relative h-32">
              {/* SVG Chart with fixed aspect ratio */}
              <svg 
                viewBox={`0 0 ${chartWidth} ${chartHeight}`} 
                class="absolute inset-0 w-full h-full" 
                preserveAspectRatio="xMidYMid meet" 
                role="img" 
                aria-label={t['detail.trend.title']}
              >
                {/* Area fill under line */}
                <defs>
                  <linearGradient id="areaGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#0ea5e9" stop-opacity="0.2" />
                    <stop offset="100%" stop-color="#0ea5e9" stop-opacity="0" />
                  </linearGradient>
                </defs>
                {trendAreaPoints && (
                  <polygon points={trendAreaPoints} fill="url(#areaGradient)" />
                )}
                {/* Main trend line */}
                <polyline
                  points={trendPolylinePoints}
                  fill="none"
                  stroke="#0284c7"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                {/* Data point dots */}
                {trendPoints.map((point, index) => (
                  <circle
                    cx={point.x}
                    cy={point.y}
                    r="3.5"
                    fill={index === trendPoints.length - 1 ? '#0284c7' : 'white'}
                    stroke="#0284c7"
                    stroke-width="2"
                  />
                ))}
              </svg>
            </div>
            {/* X-axis labels */}
            <div class="flex justify-between mt-2 text-xs text-slate-400">
              <span>{trendSeries[0]?.date?.slice(5) ?? ''}</span>
              <span>{trendSeries[trendSeries.length - 1]?.date?.slice(5) ?? ''}</span>
            </div>
          </div>
        </section>
      )}

      <!-- Pain Points -->
      {painClusters.length > 0 && (
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            {t['detail.pain.title']}
          </h2>
          <p class="mt-2 text-sm text-slate-500">{t['detail.pain.desc']}</p>
          <div class="mt-4 space-y-3">
            {painClusters.map((cluster, index) => (
              <div class="flex items-start gap-3 p-3 rounded-lg border border-slate-100 bg-slate-50/50">
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-orange-500 text-white text-xs font-bold flex items-center justify-center">
                  {index + 1}
                </span>
                <p data-l10n-en={cluster.en} data-l10n-zh={cluster.zh} class="text-sm text-slate-700 leading-relaxed">{lang === 'zh' ? cluster.zh : cluster.en}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Market Landscape -->
      {(competitorAnalysis || tamValue) && (
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <svg class="w-4 h-4 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
            {t['detail.market.title']}
          </h2>

          {/* TAM Display */}
          {tamValue && (
            <div class="mt-4 flex items-center gap-3 p-3 rounded-xl border border-violet-100 bg-violet-50/50">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-violet-100 text-violet-600">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M16 8h-6a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h6"/>
                  <path d="M12 12h.01"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-slate-500">{lang === 'zh' ? '市场规模 (TAM)' : 'Market Size (TAM)'}</p>
                <p class="text-lg font-bold text-slate-900">{tamValue}</p>
              </div>
            </div>
          )}

          {competitorAnalysis && (
            <div class={tamValue ? "mt-6" : "mt-4"}>
              <CompetitorAnalysisSection analysis={competitorAnalysis} lang={lang} />
            </div>
          )}


        </section>
      )}

      <!-- Entry Strategy -->
      {executionSteps.length > 0 && (
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
            {t['detail.entry.title']}
          </h2>
          
          <div class="mt-4 space-y-3">
            {executionSteps.map((item, index) => (
              <div class="flex gap-3">
                <div class="flex flex-col items-center">
                  <div class="w-6 h-6 rounded-full bg-slate-900 text-white text-xs font-bold flex items-center justify-center">
                    {index + 1}
                  </div>
                  {index < executionSteps.length - 1 && <div class="w-px flex-1 bg-slate-200 my-1" />}
                </div>
                <div class="flex-1 pb-2">
                  <span class="text-xs font-medium text-sky-600">{t['detail.entry.phase']} {index + 1}</span>
                  <p data-l10n-en={item.en} data-l10n-zh={item.zh} class="text-sm font-medium text-slate-900 mt-0.5">
                    {getLocalizedPairText(item, lang)}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Monetization -->
      {monetizationItems.length > 0 && (
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
            {t['detail.monetization.title']}
          </h2>
          
          <div class="mt-4 space-y-2">
            {monetizationItems.map((item, index) => (
              <div class="flex items-start gap-3 p-3 rounded-lg border border-slate-100">
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-emerald-500 text-white text-xs font-bold flex items-center justify-center">
                  {index + 1}
                </span>
                <p data-l10n-en={item.en} data-l10n-zh={item.zh} class="text-sm text-slate-700">
                  {getLocalizedPairText(item, lang)}
                </p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Risks -->
      {risks.length > 0 && (
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <svg class="w-4 h-4 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            {t['detail.risks.title']}
          </h2>

          <div class="mt-4 space-y-2">
            {risks.map((item) => (
              <div class="p-3 rounded-lg border border-amber-100 bg-amber-50/50">
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-amber-600 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                  </svg>
                  <div>
                    <p class="text-sm font-medium text-slate-800">
                      {lang === 'zh' ? item.risk.zh : item.risk.en}
                    </p>
                    <p class="text-xs text-slate-500 mt-0.5">
                      {t['detail.risks.mitigation']}: {lang === 'zh' ? item.mitigation.zh : item.mitigation.en}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          {unsuitableFor.length > 0 && (
            <div class="mt-3 p-3 rounded-lg border border-slate-100 bg-slate-50">
              <p class="text-xs text-slate-500">
                <span class="font-medium text-slate-700">{t['detail.risks.not_for']}:</span>
                {unsuitableFor.map((item, i) => (
                  <span>
                    {i > 0 ? ', ' : ' '}{lang === 'zh' ? item.zh : item.en}
                  </span>
                ))}
              </p>
            </div>
          )}
        </section>
      )}

      <!-- CTA Section -->
      <section class="bg-slate-900 rounded-2xl p-6 text-white">
        <div class="flex items-center gap-2 text-blue-300">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span class="text-sm font-medium">{t['detail.sidebar.subscribe']}</span>
        </div>
        <h2 class="text-xl font-bold mt-2">{t['detail.sidebar.weekly']}</h2>
        <p class="text-slate-400 text-sm mt-1">
          {lang === 'zh' ? '加入 ' : 'Join '}{t['detail.sidebar.subscribers']}{lang === 'zh' ? '，每周获取经过验证的机会。' : ' getting verified opportunities every week.'}
        </p>
        
        <form class="mt-4 flex gap-2" onsubmit="event.preventDefault(); alert('Thanks for subscribing!');">
          <input 
            type="email"
            placeholder={lang === 'zh' ? 'your@email.com' : 'your@email.com'}
            class="flex-1 bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-white/30"
          />
          <button 
            type="submit"
            class="bg-white text-slate-900 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-100 transition-colors"
          >
            {t['detail.sidebar.subscribe']}
          </button>
        </form>
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-4 lg:sticky lg:top-24">
      <!-- Opportunity Overview -->
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-slate-900 flex items-center gap-2">
          <svg class="w-4 h-4 text-slate-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
          {t['detail.opportunity_score']}
        </h2>
        <div class="mt-4 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs text-slate-500">{t['detail.opportunity_score.demand']}</span>
            <div class="flex gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-3.5 h-3.5 ${i < opportunityScore.demand ? 'text-amber-400 fill-amber-400' : 'text-slate-300'}`} viewBox="0 0 24 24" fill={i < opportunityScore.demand ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-slate-500">{t['detail.opportunity_score.competition']}</span>
            <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200">
              {lang === 'zh' ? '适中' : 'Moderate'}
            </span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-slate-500">{t['detail.opportunity_score.barrier']}</span>
            <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium text-emerald-700 bg-emerald-50 border border-emerald-200">
              {lang === 'zh' ? '低' : 'Low'}
            </span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-slate-500">{t['detail.opportunity_score.monetization']}</span>
            <div class="flex gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-3.5 h-3.5 ${i < opportunityScore.monetization ? 'text-amber-400 fill-amber-400' : 'text-slate-300'}`} viewBox="0 0 24 24" fill={i < opportunityScore.monetization ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
          </div>
          <div class="h-px bg-slate-100" />
          <div class="flex items-center justify-between text-xs">
            <span class="text-slate-500">{t['detail.summary.confidence']}</span>
            <span class="font-medium text-emerald-600 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              {t[confidenceInfo.labelKey]}
            </span>
          </div>
          <div class="text-xs text-slate-400">
            {lang === 'zh' ? '更新于' : 'Updated'}: {frontmatter.dataDate ?? frontmatter.date}
          </div>
        </div>
      </section>

      <!-- Quick Actions -->
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-slate-900">{t['detail.sidebar.actions']}</h2>
        <div class="mt-3 space-y-2">
          <button class="w-full flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 text-xs font-medium text-slate-600 hover:bg-slate-50 transition-colors">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            {lang === 'zh' ? '复制关键词' : 'Copy Keywords'}
          </button>
          <button class="w-full flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 text-xs font-medium text-slate-600 hover:bg-slate-50 transition-colors">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {lang === 'zh' ? '下载报告' : 'Download Report'}
          </button>
          <button class="w-full flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 text-xs font-medium text-slate-600 hover:bg-slate-50 transition-colors">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="18" cy="5" r="3"/>
              <circle cx="6" cy="12" r="3"/>
              <circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            {lang === 'zh' ? '分享' : 'Share'}
          </button>
        </div>
      </section>

      <!-- Subscribe Card -->
      <section class="rounded-2xl bg-slate-900 p-5 text-white shadow-sm">
        <svg class="w-6 h-6 text-blue-400 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        <h3 class="font-semibold text-sm">{t['detail.sidebar.subscribe']}</h3>
        <p class="text-xs text-slate-400 mt-1">{t['detail.sidebar.weekly']}</p>
        <form class="mt-3 space-y-2" onsubmit="event.preventDefault();">
          <input 
            type="email"
            placeholder={lang === 'zh' ? 'your@email.com' : 'your@email.com'}
            class="w-full bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-white/30"
          />
          <button 
            type="submit"
            class="w-full bg-white text-slate-900 py-2 rounded-lg text-xs font-semibold hover:bg-slate-100 transition-colors"
          >
            {t['detail.sidebar.subscribe']}
          </button>
        </form>
        <p class="text-xs text-slate-500 mt-2 text-center">
          1,200+ {t['detail.sidebar.subscribers']}
        </p>
      </section>
    </aside>
  </article>
</Layout>
