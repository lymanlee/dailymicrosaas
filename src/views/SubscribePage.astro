---
import Layout from '../layouts/Layout.astro';
import { type Lang, withLangPath } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const emailSubscribeUrl = import.meta.env.PUBLIC_EMAIL_SUBSCRIBE_URL?.trim();
const rssEn = '/rss.xml';
const rssZh = '/rss-zh.xml';

const pageTitleMap = {
  en: 'Subscribe - Daily Micro SaaS',
  zh: '订阅更新｜Daily Micro SaaS',
};
const pageDescriptionMap = {
  en: 'Subscribe to Daily Micro SaaS via RSS now, and use the email option when the newsletter channel is enabled.',
  zh: '现在就能通过 RSS 订阅 Daily Micro SaaS，邮件订阅入口也已作为下一步预留。',
};
const siteUrl = (Astro.site?.toString() || 'https://dailymicrosaas.pages.dev').replace(/\/$/, '');
const pageUrl = new URL(withLangPath('/subscribe', lang), `${siteUrl}/`).toString();
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: lang === 'zh' ? '订阅 Daily Micro SaaS' : 'Subscribe to Daily Micro SaaS',
  description: pageDescriptionMap[lang],
  url: pageUrl,
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en',
};

const copy = {
  kicker: {
    en: 'Subscription options',
    zh: '订阅方式',
  },
  h1: {
    en: 'Pick the channel that matches how you work',
    zh: '按你的工作方式选一个订阅入口',
  },
  subhead: {
    en: 'RSS is already live for people who want a clean feed. Email is kept as the next switch we can turn on once the newsletter channel is ready.',
    zh: 'RSS 已经可以直接用，适合想要干净信息流的人；邮件订阅也已经作为下一步预留，等邮件通道接通后就能直接打开。',
  },
  rssTitle: {
    en: 'RSS feeds',
    zh: 'RSS 订阅',
  },
  rssBody: {
    en: 'Two feeds are available: the default English feed and a Chinese feed whose article links point directly to /zh routes.',
    zh: '现在提供两个 feed：默认英文 feed，以及文章链接会直接落到 /zh 路由的中文 feed。',
  },
  rssEn: {
    en: 'English feed',
    zh: '英文 feed',
  },
  rssZh: {
    en: 'Chinese feed',
    zh: '中文 feed',
  },
  emailTitle: {
    en: 'Email updates',
    zh: '邮件更新',
  },
  emailReady: {
    en: 'Email subscription is already enabled. Use it if you prefer updates in your inbox instead of a reader.',
    zh: '邮件订阅已经开放；如果你不想用阅读器，直接走邮箱就行。',
  },
  emailSoon: {
    en: 'The page is ready for email, but the public newsletter channel is not switched on yet. Use RSS for now and email will follow.',
    zh: '页面层已经给邮件订阅留好了位置，但公开的 newsletter 通道还没打开。先用 RSS，邮件入口会跟上。',
  },
  emailCta: {
    en: 'Open email subscription',
    zh: '打开邮件订阅',
  },
  homeCta: {
    en: 'Back to today\'s pick',
    zh: '回首页看今日推荐',
  },
  whyTitle: {
    en: 'What you will get',
    zh: '你订阅后会看到什么',
  },
  whyItemsEn: [
    'One buildable Micro SaaS direction at a time — not a pile of vague inspiration.',
    'Demand signals, competition context, monetisation angle, and the fastest MVP path.',
    'A bilingual site flow, so you can read in English or Chinese without losing the right page links.',
  ],
  whyItemsZh: [
    '一次只给你一个可落地的 Micro SaaS 方向，不堆一堆空泛灵感。',
    '会一起带上需求信号、竞争判断、变现角度和最快 MVP 路径。',
    '站点链路已经支持中英文独立路由，订阅后点回页面也不会丢正确语言链接。',
  ],
} as const;
---

<Layout
  title={pageTitleMap[lang]}
  description={pageDescriptionMap[lang]}
  structuredData={structuredData}
  lang={lang}
  i18nTitle={pageTitleMap}
  i18nDescription={pageDescriptionMap}
>
  <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-sm lg:p-10">
    <span data-l10n-en={copy.kicker.en} data-l10n-zh={copy.kicker.zh} class="section-kicker">
      {lang === 'zh' ? copy.kicker.zh : copy.kicker.en}
    </span>
    <h1 data-l10n-en={copy.h1.en} data-l10n-zh={copy.h1.zh} class="mt-3 text-4xl font-black tracking-tight text-slate-950">
      {lang === 'zh' ? copy.h1.zh : copy.h1.en}
    </h1>
    <p data-l10n-en={copy.subhead.en} data-l10n-zh={copy.subhead.zh} class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
      {lang === 'zh' ? copy.subhead.zh : copy.subhead.en}
    </p>
  </section>

  <section class="mt-8 grid gap-5 lg:grid-cols-2">
    <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <h2 data-l10n-en={copy.rssTitle.en} data-l10n-zh={copy.rssTitle.zh} class="text-2xl font-bold text-slate-950">
        {lang === 'zh' ? copy.rssTitle.zh : copy.rssTitle.en}
      </h2>
      <p data-l10n-en={copy.rssBody.en} data-l10n-zh={copy.rssBody.zh} class="mt-3 leading-7 text-slate-600">
        {lang === 'zh' ? copy.rssBody.zh : copy.rssBody.en}
      </p>
      <div class="mt-5 flex flex-col gap-3">
        <a href={rssEn} class="inline-flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800 transition hover:border-primary hover:text-primary">
          <span data-l10n-en={copy.rssEn.en} data-l10n-zh={copy.rssEn.zh}>{lang === 'zh' ? copy.rssEn.zh : copy.rssEn.en}</span>
          <span class="text-slate-400">/rss.xml</span>
        </a>
        <a href={rssZh} class="inline-flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800 transition hover:border-primary hover:text-primary">
          <span data-l10n-en={copy.rssZh.en} data-l10n-zh={copy.rssZh.zh}>{lang === 'zh' ? copy.rssZh.zh : copy.rssZh.en}</span>
          <span class="text-slate-400">/rss-zh.xml</span>
        </a>
      </div>
    </div>

    <div class="rounded-[28px] border border-slate-200 bg-slate-950 p-6 text-white shadow-soft">
      <h2 data-l10n-en={copy.emailTitle.en} data-l10n-zh={copy.emailTitle.zh} class="text-2xl font-bold">
        {lang === 'zh' ? copy.emailTitle.zh : copy.emailTitle.en}
      </h2>
      <p
        data-l10n-en={emailSubscribeUrl ? copy.emailReady.en : copy.emailSoon.en}
        data-l10n-zh={emailSubscribeUrl ? copy.emailReady.zh : copy.emailSoon.zh}
        class="mt-3 leading-7 text-slate-300"
      >
        {lang === 'zh'
          ? (emailSubscribeUrl ? copy.emailReady.zh : copy.emailSoon.zh)
          : (emailSubscribeUrl ? copy.emailReady.en : copy.emailSoon.en)}
      </p>
      {emailSubscribeUrl ? (
        <a
          href={emailSubscribeUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-l10n-en={copy.emailCta.en}
          data-l10n-zh={copy.emailCta.zh}
          class="mt-5 inline-flex rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100"
        >
          {lang === 'zh' ? copy.emailCta.zh : copy.emailCta.en}
        </a>
      ) : (
        <div class="mt-5 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-300">
          {lang === 'zh' ? '当前先用 RSS 最直接。' : 'For now, RSS is the cleanest option.'}
        </div>
      )}
    </div>
  </section>

  <section class="mt-8 rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm lg:p-10">
    <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-start">
      <div>
        <h2 data-l10n-en={copy.whyTitle.en} data-l10n-zh={copy.whyTitle.zh} class="text-2xl font-bold text-slate-950">
          {lang === 'zh' ? copy.whyTitle.zh : copy.whyTitle.en}
        </h2>
        <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-600">
          {copy.whyItemsEn.map((_, index) => (
            <li
              data-l10n-en={`• ${copy.whyItemsEn[index]}`}
              data-l10n-zh={`• ${copy.whyItemsZh[index]}`}
            >
              {lang === 'zh' ? `• ${copy.whyItemsZh[index]}` : `• ${copy.whyItemsEn[index]}`}
            </li>
          ))}
        </ul>
      </div>

      <a
        href={withLangPath('/', lang)}
        data-l10n-en={copy.homeCta.en}
        data-l10n-zh={copy.homeCta.zh}
        class="inline-flex items-center justify-center rounded-full border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary"
      >
        {lang === 'zh' ? copy.homeCta.zh : copy.homeCta.en}
      </a>
    </div>
  </section>
</Layout>
