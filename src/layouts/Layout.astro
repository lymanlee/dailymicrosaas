        var META = {
          title: titleMap,
          description: descriptionMap,
        };

        function getLang() {
          try {
            var urlLang = new URLSearchParams(window.location.search).get('lang');
            if (urlLang === 'zh' || urlLang === 'en') return urlLang;
            return localStorage.getItem('dms_lang') || 'en';
          } catch (e) {
            return 'en';
          }
        }

        function buildLocalizedHref(baseHref, lang) {
          var url = new URL(baseHref, window.location.origin);
          if (lang === 'zh') {
            url.searchParams.set('lang', 'zh');
          } else {
            url.searchParams.delete('lang');
          }
          return url.pathname + url.search + url.hash;
        }

        function buildLocalizedAbsoluteUrl(baseHref, lang) {
          return new URL(buildLocalizedHref(baseHref, lang), window.location.origin).toString();
        }

        function updateMetaTag(selector, value) {
          if (!value) return;
          var el = document.querySelector(selector);
          if (el) el.setAttribute('content', value);
        }

        function setLang(lang) {
          try {
            localStorage.setItem('dms_lang', lang);
            var url = new URL(window.location.href);
            if (lang === 'zh') {
              url.searchParams.set('lang', 'zh');
            } else {
              url.searchParams.delete('lang');
            }
            window.history.replaceState({}, '', url.toString());
          } catch (e) {}
        }

        function applyLang(lang) {
          var t = UI[lang] || UI['en'];
          var title = META.title[lang] || META.title.en;
          var description = META.description[lang] || META.description.en;
          var canonical = buildLocalizedAbsoluteUrl(window.location.pathname, lang);

          document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';

          document.querySelectorAll('[data-i18n]').forEach(function (el) {
            var key = el.getAttribute('data-i18n');
            if (t[key] !== undefined) {
              el.textContent = t[key];
            }
          });

          document.querySelectorAll('[data-l10n-en][data-l10n-zh]').forEach(function (el) {
            var text = el.getAttribute(lang === 'zh' ? 'data-l10n-zh' : 'data-l10n-en');
            if (text !== null) {
              el.textContent = text;
            }
          });

          document.querySelectorAll('[data-lang-href]').forEach(function (el) {
            var baseHref = el.getAttribute('data-lang-href');
            if (!baseHref) return;
            el.setAttribute('href', buildLocalizedHref(baseHref, lang));
          });

          var label = document.getElementById('lang-label');
          if (label) label.textContent = lang === 'zh' ? 'EN' : '中文';

          if (title) document.title = title;
          updateMetaTag('meta[name="description"]', description);
          updateMetaTag('meta[http-equiv="content-language"]', lang === 'zh' ? 'zh-CN' : 'en');
          updateMetaTag('meta[property="og:title"]', title);
          updateMetaTag('meta[property="og:description"]', description);
          updateMetaTag('meta[property="og:url"]', canonical);
          updateMetaTag('meta[property="og:locale"]', lang === 'zh' ? 'zh_CN' : 'en_US');
          updateMetaTag('meta[name="twitter:title"]', title);
          updateMetaTag('meta[name="twitter:description"]', description);

          var canonicalLink = document.querySelector('link[rel="canonical"]');
          if (canonicalLink) canonicalLink.setAttribute('href', canonical);

          document.dispatchEvent(new CustomEvent('langchange', { detail: { lang: lang, t: t } }));
        }

        var lang = getLang();
        applyLang(lang);

        var btn = document.getElementById('lang-toggle');
        if (btn) {
          btn.addEventListener('click', function () {
            var current = getLang();
            var next = current === 'zh' ? 'en' : 'zh';
            setLang(next);
            applyLang(next);
          });
        }
      })();
    </script>
  </body>
