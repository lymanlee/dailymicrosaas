---
import '../styles/global.css';
import { getLangFromPath, stripLangPrefix, ui, withLangPath } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, any> | Array<Record<string, any>>;
  lang?: 'en' | 'zh';
  i18nTitle?: Partial<Record<'en' | 'zh', string>>;
  i18nDescription?: Partial<Record<'en' | 'zh', string>>;
}

const {
  title,
  description = 'One real, buildable Micro SaaS direction every day. Demand signals, competitive context, and the fastest path to a working MVP.',
  image = '/social-card.svg',
  type = 'website',
  noindex = false,
  structuredData,
  lang: pageLang,
  i18nTitle,
  i18nDescription,
} = Astro.props;

const currentLang = pageLang ?? getLangFromPath(Astro.url.pathname);
const currentBasePath = stripLangPrefix(Astro.url.pathname);
const t = ui[currentLang] ?? ui.en;

const _legacyRuntimeUiKeys = {
  en: {
    'detail.trend.title': ui.en['detail.trend.title'],
    'detail.trend.desc': ui.en['detail.trend.desc'],
    'detail.trend.peak': ui.en['detail.trend.peak'],
    'detail.trend.avg': ui.en['detail.trend.avg'],
    'detail.trend.window': ui.en['detail.trend.window'],
    'footer.subscribe': ui.en['footer.subscribe'],
  },
  zh: {
    'detail.trend.title': ui.zh['detail.trend.title'],
    'detail.trend.desc': ui.zh['detail.trend.desc'],
    'detail.trend.peak': ui.zh['detail.trend.peak'],
    'detail.trend.avg': ui.zh['detail.trend.avg'],
    'detail.trend.window': ui.zh['detail.trend.window'],
    'footer.subscribe': ui.zh['footer.subscribe'],
  },
};

const titleMap = {
  en: i18nTitle?.en ?? title,
  zh: i18nTitle?.zh ?? i18nTitle?.en ?? title,
};
const descriptionMap = {
  en: i18nDescription?.en ?? description,
  zh: i18nDescription?.zh ?? i18nDescription?.en ?? description,
};
const localizedTitle = titleMap[currentLang] ?? titleMap.en;
const localizedDescription = descriptionMap[currentLang] ?? descriptionMap.en;

const siteUrl = (Astro.site?.toString() || 'https://dailymicrosaas.pages.dev').replace(/\/$/, '');
const canonicalUrl = new URL(withLangPath(currentBasePath, currentLang), `${siteUrl}/`).toString();
const alternateEnUrl = new URL(withLangPath(currentBasePath, 'en'), `${siteUrl}/`).toString();
const alternateZhUrl = new URL(withLangPath(currentBasePath, 'zh'), `${siteUrl}/`).toString();
const socialImage = image.startsWith('http') ? image : new URL(image, `${siteUrl}/`).toString();
const robots = noindex ? 'noindex, nofollow' : 'index, follow';

const navItems = [
  { href: '/', labelKey: 'nav.today' as const },
  { href: '/archive', labelKey: 'nav.archive' as const },
  { href: '/about', labelKey: 'nav.about' as const },
];

const defaultStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Daily Micro SaaS',
  url: siteUrl,
  description: localizedDescription,
  inLanguage: currentLang === 'zh' ? 'zh-CN' : 'en',
};
const jsonLdPayload = JSON.stringify(structuredData ?? defaultStructuredData);
const htmlLang = currentLang === 'zh' ? 'zh-CN' : 'en';
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={localizedDescription} />
    <meta http-equiv="content-language" content={htmlLang} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={alternateEnUrl} />
    <link rel="alternate" hreflang="zh-CN" href={alternateZhUrl} />
    <link rel="alternate" hreflang="x-default" href={alternateEnUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Daily Micro SaaS" />
    <meta property="og:title" content={localizedTitle} />
    <meta property="og:description" content={localizedDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content={currentLang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={currentLang === 'zh' ? 'en_US' : 'zh_CN'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={localizedTitle} />
    <meta name="twitter:description" content={localizedDescription} />
    <meta name="twitter:image" content={socialImage} />

    <title>{localizedTitle}</title>
    <script type="application/ld+json" set:html={jsonLdPayload}></script>
  </head>
  <body class="min-h-screen text-slate-900 antialiased">
    <div class="min-h-screen">
      <header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur-md">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-3">
            <a href={withLangPath('/', currentLang)} class="flex items-center gap-3 text-slate-950 transition hover:opacity-90">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-slate-950 text-sm font-black text-white shadow-soft">DM</span>
              <div>
                <p class="text-base font-semibold tracking-tight">Daily Micro SaaS</p>
                <p class="text-xs text-slate-500">{t['nav.tagline']}</p>
              </div>
            </a>
          </div>

          <nav class="hidden items-center gap-2 rounded-full border border-slate-200 bg-white/80 p-1 text-sm text-slate-600 md:flex">
            {navItems.map((item) => {
              const isActive = item.href === '/' ? currentBasePath === '/' : currentBasePath.startsWith(item.href);
              return (
                <a
                  href={withLangPath(item.href, currentLang)}
                  class={`rounded-full px-4 py-2 transition ${isActive ? 'bg-slate-950 text-white shadow-sm' : 'hover:bg-slate-100 hover:text-slate-900'}`}
                >
                  {t[item.labelKey]}
                </a>
              );
            })}
          </nav>

          <div class="flex items-center gap-2">
            <button
              id="lang-toggle"
              type="button"
              aria-label="Switch language"
              class="inline-flex items-center gap-1.5 rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-600 transition hover:border-slate-300 hover:bg-slate-50"
            >
              <span class="text-sm leading-none">🌐</span>
              <span>{currentLang === 'zh' ? 'EN' : '中文'}</span>
            </button>

            <a
              href={withLangPath('/archive', currentLang)}
              class="hidden rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary md:inline-flex"
            >
              {t['nav.browse']}
            </a>
          </div>
        </div>
      </header>

      <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8 lg:py-10">
        <slot />
      </main>

      <footer class="mt-16 border-t border-slate-200 bg-white/90">
        <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 text-sm text-slate-600 sm:px-6 lg:grid-cols-[1.4fr_1fr] lg:px-8">
          <div>
            <p class="mb-3 text-lg font-semibold text-slate-900">Daily Micro SaaS</p>
            <p class="max-w-2xl leading-7">
              {t['footer.desc']}
            </p>
          </div>
          <div class="grid gap-3 text-slate-500">
            <a href={withLangPath('/', currentLang)} class="transition hover:text-primary">{t['nav.today']}</a>
            <a href={withLangPath('/archive', currentLang)} class="transition hover:text-primary">{t['nav.archive']}</a>
            <a href={withLangPath('/about', currentLang)} class="transition hover:text-primary">{t['nav.about']}</a>
            <a href={withLangPath('/subscribe', currentLang)} class="transition hover:text-primary">{t['footer.subscribe']}</a>
            <p class="pt-2 text-xs text-slate-400">{t['footer.mvp_notice']}</p>
          </div>
        </div>
      </footer>
    </div>

    <script is:inline>
      (function () {
        function getPathLang(pathname) {
          return pathname === '/zh' || pathname.indexOf('/zh/') === 0 ? 'zh' : 'en';
        }

        function stripLangPrefix(path) {
          var url = new URL(path, window.location.origin);
          if (url.pathname === '/zh') {
            url.pathname = '/';
          } else if (url.pathname.indexOf('/zh/') === 0) {
            url.pathname = url.pathname.slice(3) || '/';
          }
          return url.pathname + url.search + url.hash;
        }

        function withLangPath(path, lang) {
          var url = new URL(stripLangPrefix(path), window.location.origin);
          var pathname = url.pathname || '/';
          url.pathname = lang === 'zh'
            ? (pathname === '/' ? '/zh' : '/zh' + pathname)
            : pathname;
          return url.pathname + url.search + url.hash;
        }

        function redirectLegacyLangQuery() {
          var url = new URL(window.location.href);
          var legacyLang = url.searchParams.get('lang');
          if (legacyLang !== 'zh' && legacyLang !== 'en') {
            return false;
          }

          url.searchParams.delete('lang');
          var target = withLangPath(url.pathname + url.search + url.hash, legacyLang);
          if (target !== window.location.pathname + window.location.search + window.location.hash) {
            window.location.replace(target);
            return true;
          }
          return false;
        }

        if (redirectLegacyLangQuery()) {
          return;
        }

        var toggle = document.getElementById('lang-toggle');
        if (!toggle) {
          return;
        }

        toggle.addEventListener('click', function () {
          var current = getPathLang(window.location.pathname);
          var next = current === 'zh' ? 'en' : 'zh';
          var target = withLangPath(window.location.pathname + window.location.search + window.location.hash, next);
          window.location.assign(target);
        });
      })();
    </script>
  </body>
</html>
