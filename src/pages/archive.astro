---
import Layout from '../layouts/Layout.astro';
import IdeaCard from '../components/IdeaCard.astro';
import { getCollection } from 'astro:content';

const allIdeas = await getCollection('ideas');
const publishedIdeas = allIdeas.filter((idea) => idea.slug !== 'template');

const ideas = publishedIdeas
  .map((idea) => ({
    ...idea.data,
    slug: idea.slug,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const categories = [...new Set(ideas.map((idea) => idea.category))];
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Daily Micro SaaS Archive',
  description: 'Browse all Micro SaaS directions we have broken down, filtered by category.',
  url: 'https://dailymicrosaas.pages.dev/archive',
};
---

<Layout title="Archive - Daily Micro SaaS" description="Browse all Micro SaaS directions we have broken down, filtered by category." structuredData={structuredData}>
  <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-sm lg:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span data-i18n="archive.kicker" class="section-kicker">Archive</span>
        <h1 data-i18n="archive.h1" class="mt-3 text-4xl font-black tracking-tight text-slate-950">All the directions we've broken down</h1>
        <p data-i18n="archive.subhead" class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
          Compare opportunity density across categories, or read a few in a row to find the best fit for your current skillset.
        </p>
      </div>
      <div class="grid gap-2 rounded-3xl bg-slate-50 p-4 text-sm text-slate-600 sm:grid-cols-2">
        <div>
          <p data-i18n="archive.count.label" class="font-semibold text-slate-900">Total ideas</p>
          <p>{ideas.length}</p>
        </div>
        <div>
          <p data-i18n="archive.cat.label" class="font-semibold text-slate-900">Categories</p>
          <p>{categories.length}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-8 rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex flex-wrap items-center gap-3">
      <span data-i18n="archive.filter.label" class="text-sm font-semibold text-slate-500">Filter by category:</span>
      <button type="button" data-filter-btn data-category="ALL" class="rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white" data-i18n-content="archive.filter.all">All</button>
      {categories.map((cat) => (
        <button
          type="button"
          data-filter-btn
          data-category={cat}
          class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200"
        >
          {cat}
        </button>
      ))}
    </div>
    <p id="archive-filter-hint" data-i18n="archive.filter.hint" class="text-sm text-slate-500">Showing all. Click a category to filter.</p>
  </section>

  <section class="mt-8">
    {ideas.length > 0 ? (
      <div id="archive-list" class="grid gap-5 lg:grid-cols-2">
        {ideas.map((idea) => (
          <div data-archive-item data-category={idea.category}>
            <IdeaCard
              title={idea.title}
              slug={idea.slug}
              date={idea.date}
              category={idea.category}
              difficulty={idea.difficulty}
              description={idea.description}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="rounded-[28px] border border-dashed border-slate-300 bg-white p-10 text-center text-slate-500">
        <span data-i18n="archive.empty">Nothing here yet. More coming soon.</span>
      </div>
    )}
  </section>

  <script is:inline>
    var buttons = Array.from(document.querySelectorAll('[data-filter-btn]'));
    var cards = Array.from(document.querySelectorAll('[data-archive-item]'));
    var hint = document.getElementById('archive-filter-hint');
    var params = new URLSearchParams(window.location.search);
    // "ALL" sentinel replaces "全部" so it works in both languages
    var initialCategory = params.get('category') || 'ALL';

    var filterActive = initialCategory;

    function getT() {
      try {
        var lang = localStorage.getItem('dms_lang') || 'en';
        // Use the global UI dict injected by Layout
        return window.__DMS_UI__ ? window.__DMS_UI__[lang] : null;
      } catch(e) { return null; }
    }

    var applyFilter = function(category, syncUrl) {
      filterActive = category;
      cards.forEach(function(card) {
        var visible = category === 'ALL' || card.dataset.category === category;
        card.style.display = visible ? '' : 'none';
      });

      buttons.forEach(function(button) {
        var active = button.dataset.category === category;
        button.className = active
          ? 'rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white'
          : 'rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200';
      });

      if (hint) {
        var t = getT();
        if (category === 'ALL') {
          hint.textContent = (t && t['archive.filter.hint']) || 'Showing all. Click a category to filter.';
        } else {
          var prefix = (t && t['archive.filter.active']) || 'Showing';
          hint.textContent = prefix + ': ' + category;
        }
      }

      if (syncUrl !== false) {
        var nextUrl = category === 'ALL' ? '/archive' : '/archive?category=' + encodeURIComponent(category);
        window.history.replaceState({}, '', nextUrl);
      }
    };

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        applyFilter(button.dataset.category || 'ALL');
      });
    });

    // Handle legacy ?category= params that may use Chinese category names
    var availableCategories = new Set(buttons.map(function(b) { return b.dataset.category; }));
    var startCat = availableCategories.has(initialCategory) ? initialCategory : 'ALL';
    applyFilter(startCat, false);

    // Re-apply hint text when language changes
    document.addEventListener('langchange', function() {
      applyFilter(filterActive, false);
    });
  </script>
</Layout>
