---
import Layout from '../layouts/Layout.astro';
import IdeaCard from '../components/IdeaCard.astro';
import { getCollection } from 'astro:content';

const allIdeas = await getCollection('ideas');
const publishedIdeas = allIdeas.filter((idea) => idea.slug !== 'template');

const ideas = publishedIdeas
  .map((idea) => ({
    ...idea.data,
    slug: idea.slug,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const categories = [...new Set(ideas.map((idea) => idea.category))];
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Daily Micro SaaS 历史归档',
  description: '按分类查看已整理的 Micro SaaS 方向归档。',
  url: 'https://dailymicrosaas.pages.dev/archive',
};
---

<Layout title="历史归档 - Daily Micro SaaS" description="按分类查看已整理过的 Micro SaaS 方向归档。" structuredData={structuredData}>
  <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-sm lg:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="section-kicker">历史归档</span>
        <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950">按赛道翻查已经拆过的方向</h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
          这里适合做两件事：一是对比不同赛道的机会密度，二是连续看几条后找出最适合你当前执行力的题目。
        </p>
      </div>
      <div class="grid gap-2 rounded-3xl bg-slate-50 p-4 text-sm text-slate-600 sm:grid-cols-2">
        <div>
          <p class="font-semibold text-slate-900">当前归档</p>
          <p>{ideas.length} 条</p>
        </div>
        <div>
          <p class="font-semibold text-slate-900">覆盖分类</p>
          <p>{categories.length} 类</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-8 rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex flex-wrap items-center gap-3">
      <span class="text-sm font-semibold text-slate-500">按分类筛选：</span>
      <button type="button" data-filter-btn data-category="全部" class="rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white">全部</button>
      {categories.map((cat) => (
        <button
          type="button"
          data-filter-btn
          data-category={cat}
          class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200"
        >
          {cat}
        </button>
      ))}
    </div>
    <p id="archive-filter-hint" class="text-sm text-slate-500">默认展示全部方向，可点击上方标签快速筛选。</p>
  </section>

  <section class="mt-8">
    {ideas.length > 0 ? (
      <div id="archive-list" class="grid gap-5 lg:grid-cols-2">
        {ideas.map((idea) => (
          <div data-archive-item data-category={idea.category}>
            <IdeaCard
              title={idea.title}
              slug={idea.slug}
              date={idea.date}
              category={idea.category}
              difficulty={idea.difficulty}
              description={idea.description}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="rounded-[28px] border border-dashed border-slate-300 bg-white p-10 text-center text-slate-500">
        暂无内容，敬请期待。
      </div>
    )}
  </section>

  <script is:inline>
    const buttons = Array.from(document.querySelectorAll('[data-filter-btn]'));
    const cards = Array.from(document.querySelectorAll('[data-archive-item]'));
    const hint = document.getElementById('archive-filter-hint');
    const params = new URLSearchParams(window.location.search);
    const initialCategory = params.get('category') || '全部';

    const applyFilter = (category, syncUrl = true) => {
      cards.forEach((card) => {
        const visible = category === '全部' || card.dataset.category === category;
        card.style.display = visible ? '' : 'none';
      });

      buttons.forEach((button) => {
        const active = button.dataset.category === category;
        button.className = active
          ? 'rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white'
          : 'rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200';
      });

      if (hint) {
        hint.textContent = category === '全部' ? '默认展示全部方向，可点击上方标签快速筛选。' : `当前只展示「${category}」分类下的方向。`;
      }

      if (syncUrl) {
        const nextUrl = category === '全部' ? '/archive' : `/archive?category=${encodeURIComponent(category)}`;
        window.history.replaceState({}, '', nextUrl);
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => applyFilter(button.dataset.category || '全部'));
    });

    const availableCategories = new Set(buttons.map((button) => button.dataset.category));
    applyFilter(availableCategories.has(initialCategory) ? initialCategory : '全部', false);
  </script>
</Layout>
