---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page not found - Daily Micro SaaS" description="The page you're looking for doesn't exist." noindex={true}>
  <section class="mx-auto max-w-3xl rounded-[32px] border border-slate-200 bg-white p-10 text-center shadow-sm lg:p-14">
    <p class="section-kicker mx-auto justify-center">404</p>
    <h1 data-i18n="404.h1" class="mt-5 text-4xl font-black tracking-tight text-slate-950">Nothing here.</h1>
    <p data-i18n="404.p" class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-600">
      The link is either gone or was never published. Head back and find something worth building.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/" data-i18n="404.btn_home" class="inline-flex items-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary">
        Go home
      </a>
      <a href="/archive" data-i18n="404.btn_archive" class="inline-flex items-center rounded-full border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary">
        Browse ideas
      </a>
    </div>
  </section>
</Layout>
