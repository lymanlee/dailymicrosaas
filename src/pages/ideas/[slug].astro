---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ui, type Lang, withLangPath } from '../../lib/i18n';
import {
  buildLocalizedExecutionSteps,
  buildLocalizedFullBreakdown,
  buildLocalizedMonetizationItems,
  buildLocalizedWhyNow,
  buildSourceSignalCards,
  estimateReadingTime,
  getCategoryInfo,
  getLocalizedPairText,
  getLocalizedTextStrict,
  getSection,
  parseIdeaSections,
} from '../../lib/idea';

export async function getStaticPaths() {
  const ideas = await getCollection('ideas');
  const publishedIdeas = ideas.filter((idea) => idea.slug !== 'template');

  return publishedIdeas.map((idea: any) => ({
    params: { slug: idea.slug },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const pageLang: Lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const t = ui[pageLang] ?? ui.en;
const { data: frontmatter } = idea;
const rawContent = idea.body ?? '';
const sections = parseIdeaSections(rawContent);
const readingTime = estimateReadingTime(rawContent);
const demandSection = getSection(sections, ['真实需求来源']);
const keywordsSection = getSection(sections, ['SEO 关键词']);

const keywordItems = keywordsSection?.bullets.slice(0, 5).map((item) => item.replace(/\s*\([^\)]*\)/g, '').trim()) ?? [];
const evidenceLinks = frontmatter.evidenceLinks ?? [];
const sourceSignalCards = buildSourceSignalCards(demandSection, evidenceLinks);
const convictionItems = buildLocalizedWhyNow(frontmatter, demandSection);
const monetizationItems = buildLocalizedMonetizationItems(frontmatter.category ?? '');
const executionSteps = buildLocalizedExecutionSteps(frontmatter.sourceKeyword ?? '', frontmatter.difficulty ?? 'Medium');
const fullBreakdownSections = buildLocalizedFullBreakdown(frontmatter, demandSection, keywordItems);
const localizedTitleEn = getLocalizedTextStrict(frontmatter.title, 'en', 'title');
const localizedTitleZh = getLocalizedTextStrict(frontmatter.title, 'zh', 'title');
const localizedDescriptionEn = getLocalizedTextStrict(frontmatter.description, 'en', 'description');
const localizedDescriptionZh = getLocalizedTextStrict(frontmatter.description, 'zh', 'description');
const bestWedgeEn = getLocalizedTextStrict(frontmatter.bestWedge, 'en', 'bestWedge');
const bestWedgeZh = getLocalizedTextStrict(frontmatter.bestWedge, 'zh', 'bestWedge');
const dataWindowEn = getLocalizedTextStrict(frontmatter.dataWindow, 'en', 'dataWindow');
const dataWindowZh = getLocalizedTextStrict(frontmatter.dataWindow, 'zh', 'dataWindow');
const buildWindowEn = getLocalizedTextStrict(frontmatter.buildWindow, 'en', 'buildWindow');
const buildWindowZh = getLocalizedTextStrict(frontmatter.buildWindow, 'zh', 'buildWindow');
const painClusters = (frontmatter.painClusters ?? []).map((item, index) => ({
  en: getLocalizedTextStrict(item, 'en', `painClusters[${index}]`),
  zh: getLocalizedTextStrict(item, 'zh', `painClusters[${index}]`),
}));
const competitorGaps = (frontmatter.competitorGaps ?? []).map((item, index) => ({
  en: getLocalizedTextStrict(item, 'en', `competitorGaps[${index}]`),
  zh: getLocalizedTextStrict(item, 'zh', `competitorGaps[${index}]`),
}));
const siteUrl = (Astro.site?.toString() || 'https://dailymicrosaas.pages.dev').replace(/\/$/, '');
const articleUrl = new URL(withLangPath(Astro.url.pathname, pageLang), `${siteUrl}/`).toString();
const pageTitleMap = {
  en: `${localizedTitleEn} - Daily Micro SaaS`,
  zh: `${localizedTitleZh}｜Daily Micro SaaS 拆解`,
};
const pageDescriptionMap = {
  en: localizedDescriptionEn,
  zh: localizedDescriptionZh || `围绕 ${localizedTitleZh} 的 Micro SaaS 机会拆解：需求信号、竞争判断、变现方式和最快落地路径。`,
};
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageLang === 'zh' ? localizedTitleZh : localizedTitleEn,
  description: pageDescriptionMap[pageLang],
  datePublished: frontmatter.date,
  dateModified: frontmatter.dataDate ?? frontmatter.date,
  inLanguage: pageLang === 'zh' ? 'zh-CN' : 'en',
  articleSection: pageLang === 'zh' ? getCategoryInfo(frontmatter.category).zh : getCategoryInfo(frontmatter.category).en,
  mainEntityOfPage: articleUrl,
  author: {
    '@type': 'Organization',
    name: 'Daily Micro SaaS',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Daily Micro SaaS',
  },
  image: [new URL('/social-card.svg', `${siteUrl}/`).toString()],
  keywords: keywordItems.join(', '),
};

const difficultyMeta: Record<string, { labelKey: string; label: string; classes: string }> = {
  Easy: { labelKey: 'card.difficulty.easy', label: 'Quick to validate', classes: 'bg-emerald-50 text-emerald-700 ring-emerald-200' },
  Medium: { labelKey: 'card.difficulty.medium', label: 'Needs some polish', classes: 'bg-amber-50 text-amber-700 ring-amber-200' },
  Hard: { labelKey: 'card.difficulty.hard', label: 'Execution-heavy', classes: 'bg-rose-50 text-rose-700 ring-rose-200' },
};

const difficultyInfo = difficultyMeta[frontmatter.difficulty] ?? { labelKey: 'card.difficulty.easy', label: frontmatter.difficulty, classes: 'bg-slate-100 text-slate-700 ring-slate-200' };
const categoryInfo = getCategoryInfo(frontmatter.category);

const verdictConfig: Record<string, { labelKey: string; emoji: string; bg: string; text: string; ring: string; bar: string }> = {
  'Worth Building': {
    labelKey: 'detail.verdict.worth_building',
    emoji: '✅',
    bg: 'bg-emerald-50',
    text: 'text-emerald-800',
    ring: 'ring-emerald-200',
    bar: 'bg-emerald-500',
  },
  'Watch': {
    labelKey: 'detail.verdict.watch',
    emoji: '👀',
    bg: 'bg-amber-50',
    text: 'text-amber-800',
    ring: 'ring-amber-200',
    bar: 'bg-amber-400',
  },
  'Skip': {
    labelKey: 'detail.verdict.skip',
    emoji: '⏭️',
    bg: 'bg-slate-50',
    text: 'text-slate-600',
    ring: 'ring-slate-200',
    bar: 'bg-slate-400',
  },
};
const verdict = frontmatter.verdict ?? (
  frontmatter.sourceGrade === 'worth_it' ? 'Worth Building' :
  frontmatter.sourceGrade === 'watch' ? 'Watch' : 'Skip'
);
const verdictInfo = verdictConfig[verdict] ?? verdictConfig['Watch'];

const confidenceConfig: Record<string, { labelKey: string; dots: number; color: string }> = {
  'High': { labelKey: 'detail.confidence.high', dots: 3, color: 'bg-emerald-500' },
  'Medium': { labelKey: 'detail.confidence.medium', dots: 2, color: 'bg-amber-400' },
  'Low': { labelKey: 'detail.confidence.low', dots: 1, color: 'bg-slate-400' },
};
const confidence = frontmatter.confidence ?? 'Medium';
const confidenceInfo = confidenceConfig[confidence] ?? confidenceConfig['Medium'];

const score = frontmatter.sourceScore ?? 0;
const scorePercent = Math.min(Math.round(score), 100);
const scoreLabelEn = `${t['detail.summary.score']} ${score.toFixed(1)} / 100`;
const scoreLabelZh = `评分 ${score.toFixed(1)} / 100`;

const quickFacts = [
  { labelKey: 'detail.reading_time', en: `${readingTime} min`, zh: `${readingTime} 分钟` },
  { labelKey: 'detail.difficulty', en: difficultyInfo.label, zh: difficultyInfo.label, valueKey: difficultyInfo.labelKey },
  { labelKey: 'detail.timeline', en: buildWindowEn, zh: buildWindowZh },
  { labelKey: 'detail.published', en: frontmatter.date, zh: frontmatter.date },
];

const trendSeries = Array.isArray(frontmatter.trendSeries)
  ? frontmatter.trendSeries.filter((item) => typeof item?.date === 'string' && typeof item?.value === 'number')
  : [];
const chartWidth = 100;
const chartHeight = 44;
const trendPeak = trendSeries.length ? Math.max(...trendSeries.map((item) => item.value), 0) : 0;
const trendFloor = trendSeries.length ? Math.min(...trendSeries.map((item) => item.value), 0) : 0;
const trendRange = Math.max(trendPeak - trendFloor, 10);
const trendPolylinePoints = trendSeries.map((item, index) => {
  const x = trendSeries.length === 1 ? chartWidth / 2 : (index / Math.max(trendSeries.length - 1, 1)) * chartWidth;
  const y = chartHeight - ((item.value - trendFloor) / trendRange) * chartHeight;
  return `${x.toFixed(2)},${y.toFixed(2)}`;
}).join(' ');
const trendAreaPoints = trendPolylinePoints ? `${trendPolylinePoints} ${chartWidth},${chartHeight} 0,${chartHeight}` : '';
const trendRecentWindow = trendSeries.slice(-7);
const trendRecentAvg = trendRecentWindow.length
  ? Math.round((trendRecentWindow.reduce((sum, item) => sum + item.value, 0) / trendRecentWindow.length) * 10) / 10
  : 0;
const trendStartLabel = trendSeries[0]?.date ?? '';
const trendEndLabel = trendSeries[trendSeries.length - 1]?.date ?? '';
---

<Layout
  title={pageTitleMap[pageLang]}
  description={pageDescriptionMap[pageLang]}
  type="article"
  structuredData={structuredData}
  lang={pageLang}
  i18nTitle={pageTitleMap}
  i18nDescription={pageDescriptionMap}
>
  <div class="mb-6">
    <a href={withLangPath('/', pageLang)} data-lang-href="/" data-i18n="detail.back" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 transition hover:text-primary">
      {t['detail.back']}
    </a>
  </div>

  <article class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-start">
    <div class="space-y-8">
      <section class="overflow-hidden rounded-[32px] border border-slate-200 bg-white shadow-sm">
        <div class="flex flex-wrap items-center gap-3 border-b border-slate-100 px-8 py-5">
          <span
            data-l10n-en={categoryInfo.en}
            data-l10n-zh={categoryInfo.zh}
            class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset ${categoryInfo.classes}`}
          >
            {pageLang === 'zh' ? categoryInfo.zh : categoryInfo.en}
          </span>
          <span data-i18n={difficultyInfo.labelKey} class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset ${difficultyInfo.classes}`}>
            {t[difficultyInfo.labelKey]}
          </span>
          {frontmatter.status === 'New' && (
            <span data-i18n="detail.status.new" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-200">
              {t['detail.status.new']}
            </span>
          )}
          <time class="ml-auto text-sm font-medium text-slate-400">{frontmatter.date}</time>
        </div>

        <div class="px-8 pt-7 pb-6">
          <h1
            data-l10n-en={localizedTitleEn}
            data-l10n-zh={localizedTitleZh}
            class="max-w-4xl text-4xl font-black tracking-tight text-slate-950 sm:text-5xl"
          >
            {pageLang === 'zh' ? localizedTitleZh : localizedTitleEn}
          </h1>
          <p
            data-l10n-en={localizedDescriptionEn}
            data-l10n-zh={localizedDescriptionZh}
            class="mt-4 max-w-3xl text-lg leading-8 text-slate-600"
          >
            {pageLang === 'zh' ? localizedDescriptionZh : localizedDescriptionEn}
          </p>
        </div>

        <div class="grid gap-px bg-slate-100 lg:grid-cols-3">
          <div class={`flex flex-col gap-3 bg-white px-8 py-6 ${verdictInfo.bg}`}>
            <p data-i18n="detail.summary.verdict" class="text-xs font-bold uppercase tracking-widest text-slate-500">{t['detail.summary.verdict']}</p>
            <div class="flex items-center gap-2">
              <span class="text-2xl leading-none">{verdictInfo.emoji}</span>
              <span data-i18n={verdictInfo.labelKey} class={`text-xl font-black ${verdictInfo.text}`}>{t[verdictInfo.labelKey]}</span>
            </div>
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-200">
              <div class={`h-full rounded-full ${verdictInfo.bar}`} style={`width: ${scorePercent}%`}></div>
            </div>
            <p data-l10n-en={scoreLabelEn} data-l10n-zh={scoreLabelZh} class="text-xs text-slate-500">{pageLang === 'zh' ? scoreLabelZh : scoreLabelEn}</p>
          </div>

          <div class="flex flex-col gap-3 bg-white px-8 py-6">
            <p data-i18n="detail.summary.confidence" class="text-xs font-bold uppercase tracking-widest text-slate-500">{t['detail.summary.confidence']}</p>
            <div class="flex items-center gap-2">
              <div class="flex gap-1">
                {[1, 2, 3].map((dot) => (
                  <span class={`inline-block h-4 w-4 rounded-full ${dot <= confidenceInfo.dots ? confidenceInfo.color : 'bg-slate-200'}`}></span>
                ))}
              </div>
              <span data-i18n={confidenceInfo.labelKey} class="text-lg font-bold text-slate-800">{t[confidenceInfo.labelKey]}</span>
            </div>
            {frontmatter.dataWindow && (
              <p class="text-xs text-slate-500">
                <span data-i18n="detail.summary.data_window">{t['detail.summary.data_window']}</span>: <span data-l10n-en={dataWindowEn} data-l10n-zh={dataWindowZh} class="font-semibold text-slate-700">{pageLang === 'zh' ? dataWindowZh : dataWindowEn}</span>
                {frontmatter.dataDate && (
                  <>
                    <span class="mx-1">·</span>
                    <span data-i18n="detail.summary.updated">{t['detail.summary.updated']}</span>
                    <span class="font-semibold text-slate-700"> {frontmatter.dataDate}</span>
                  </>
                )}
              </p>
            )}
          </div>

          <div class="flex flex-col gap-3 bg-white px-8 py-6">
            <p data-i18n="detail.summary.best_wedge" class="text-xs font-bold uppercase tracking-widest text-slate-500">{t['detail.summary.best_wedge']}</p>
            <p data-l10n-en={bestWedgeEn} data-l10n-zh={bestWedgeZh} class="text-base font-semibold leading-7 text-slate-900">
              {pageLang === 'zh' ? bestWedgeZh : bestWedgeEn}
            </p>
          </div>
        </div>
      </section>

      {trendSeries.length > 1 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <span data-i18n="detail.trend.title" class="section-kicker">{t['detail.trend.title']}</span>
              <p data-i18n="detail.trend.desc" class="mt-2 text-sm text-slate-500">{t['detail.trend.desc']}</p>
            </div>
            <div class="grid gap-2 text-right text-xs font-semibold text-slate-500 sm:grid-cols-2 sm:text-left">
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p data-i18n="detail.trend.peak" class="uppercase tracking-[0.12em] text-slate-400">{t['detail.trend.peak']}</p>
                <p class="mt-1 text-lg font-black text-slate-900">{trendPeak}</p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p data-i18n="detail.trend.avg" class="uppercase tracking-[0.12em] text-slate-400">{t['detail.trend.avg']}</p>
                <p class="mt-1 text-lg font-black text-slate-900">{trendRecentAvg}</p>
              </div>
            </div>
          </div>

          <div class="mt-6 rounded-[28px] border border-sky-100 bg-sky-50/70 p-4 sm:p-5">
            <svg viewBox={`0 0 ${chartWidth} ${chartHeight + 2}`} class="h-52 w-full overflow-visible" role="img" aria-label={t['detail.trend.title']}>
              <defs>
                <linearGradient id="trend-fill" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#0ea5e9" stop-opacity="0.28"></stop>
                  <stop offset="100%" stop-color="#0ea5e9" stop-opacity="0"></stop>
                </linearGradient>
              </defs>
              {[0, 1, 2, 3].map((step) => (
                <line
                  x1="0"
                  x2={chartWidth}
                  y1={(chartHeight / 3) * step}
                  y2={(chartHeight / 3) * step}
                  stroke="#cbd5e1"
                  stroke-dasharray="2 3"
                  stroke-width="0.5"
                />
              ))}
              {trendAreaPoints && <polygon points={trendAreaPoints} fill="url(#trend-fill)"></polygon>}
              <polyline
                points={trendPolylinePoints}
                fill="none"
                stroke="#0284c7"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></polyline>
            </svg>
            <div class="mt-4 flex items-center justify-between gap-3 text-xs font-semibold text-slate-500">
              <span>{trendStartLabel}</span>
              <span data-i18n="detail.trend.window">{t['detail.trend.window']}</span>
              <span>{trendEndLabel}</span>
            </div>
          </div>
        </section>
      )}

      {painClusters.length > 0 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
          <span data-i18n="detail.pain.title" class="section-kicker">{t['detail.pain.title']}</span>
          <p data-i18n="detail.pain.desc" class="mt-2 text-sm text-slate-500">{t['detail.pain.desc']}</p>
          <div class="mt-5 grid gap-3 md:grid-cols-2">
            {painClusters.map((cluster) => (
              <div class="flex items-start gap-3 rounded-2xl border border-orange-100 bg-orange-50 p-4">
                <span class="mt-0.5 text-base leading-none text-orange-500">⚡</span>
                <p data-l10n-en={cluster.en} data-l10n-zh={cluster.zh} class="text-sm font-semibold leading-7 text-slate-800">{pageLang === 'zh' ? cluster.zh : cluster.en}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {competitorGaps.length > 0 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
          <span data-i18n="detail.gaps.title" class="section-kicker">{t['detail.gaps.title']}</span>
          <p data-i18n="detail.gaps.desc" class="mt-2 text-sm text-slate-500">{t['detail.gaps.desc']}</p>
          <div class="mt-5 space-y-3">
            {competitorGaps.map((gap) => (
              <div class="flex items-start gap-3 rounded-2xl border border-violet-100 bg-violet-50 p-4">
                <span class="mt-0.5 text-base leading-none text-violet-500">🔍</span>
                <p data-l10n-en={gap.en} data-l10n-zh={gap.zh} class="text-sm font-semibold leading-7 text-slate-800">{pageLang === 'zh' ? gap.zh : gap.en}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {convictionItems.length > 0 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
          <span data-i18n="detail.why" class="section-kicker">{t['detail.why']}</span>
          <div class="mt-5 grid gap-4 md:grid-cols-2">
            {convictionItems.map((item) => (
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <p
                  data-l10n-en={item.en}
                  data-l10n-zh={item.zh}
                  class="text-sm font-semibold leading-7 text-slate-700"
                >
                  {getLocalizedPairText(item, pageLang)}
                </p>
              </div>
            ))}
          </div>
        </section>
      )}

      {sourceSignalCards.length > 0 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
          <span data-i18n="detail.sources" class="section-kicker">{t['detail.sources']}</span>
          <div class="mt-5 grid gap-4 md:grid-cols-3">
            {sourceSignalCards.map((item) => (
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <p
                  data-l10n-en={item.source.en}
                  data-l10n-zh={item.source.zh}
                  class="text-xs font-bold uppercase tracking-[0.14em] text-slate-400"
                >
                  {getLocalizedPairText(item.source, pageLang)}
                </p>
                <p
                  data-l10n-en={item.title.en}
                  data-l10n-zh={item.title.zh}
                  class="mt-3 text-base font-semibold leading-7 text-slate-800"
                >
                  {getLocalizedPairText(item.title, pageLang)}
                </p>
                <p
                  data-l10n-en={item.meta.en}
                  data-l10n-zh={item.meta.zh}
                  class="mt-2 text-sm leading-6 text-slate-500"
                >
                  {getLocalizedPairText(item.meta, pageLang)}
                </p>
              </div>
            ))}
          </div>

          {evidenceLinks.length > 0 && (
            <div class="mt-5 space-y-2">
              <p data-i18n="detail.evidence.title" class="text-xs font-bold uppercase tracking-widest text-slate-400">{t['detail.evidence.title']}</p>
              {evidenceLinks.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 px-4 py-3 text-sm transition hover:border-sky-200 hover:bg-sky-50"
                >
                  <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-slate-200 text-[10px] font-bold uppercase text-slate-600">{link.source.slice(0, 2)}</span>
                  <span class="flex-1 truncate font-medium text-slate-700">{link.title}</span>
                  <span class="shrink-0 text-slate-400">↗</span>
                </a>
              ))}
            </div>
          )}
        </section>
      )}

      <section class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
        <span data-i18n="detail.full" class="section-kicker">{t['detail.full']}</span>
        <div class="mt-6 space-y-8">
          {fullBreakdownSections.map((section) => (
            <section class="space-y-4 border-t border-slate-100 pt-6 first:border-t-0 first:pt-0">
              <h3
                data-l10n-en={section.title.en}
                data-l10n-zh={section.title.zh}
                class="text-2xl font-black tracking-tight text-slate-950"
              >
                {getLocalizedPairText(section.title, pageLang)}
              </h3>

              {section.paragraphs && section.paragraphs.length > 0 && (
                <div class="space-y-3 text-base leading-8 text-slate-700">
                  {section.paragraphs.map((paragraph) => (
                    <p data-l10n-en={paragraph.en} data-l10n-zh={paragraph.zh}>
                      {getLocalizedPairText(paragraph, pageLang)}
                    </p>
                  ))}
                </div>
              )}

              {section.bullets && section.bullets.length > 0 && (
                <ul class="space-y-3 text-base leading-8 text-slate-700">
                  {section.bullets.map((bullet) => (
                    <li class="flex gap-3">
                      <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-900"></span>
                      <span data-l10n-en={bullet.en} data-l10n-zh={bullet.zh}>{getLocalizedPairText(bullet, pageLang)}</span>
                    </li>
                  ))}
                </ul>
              )}

              {section.numbered && section.numbered.length > 0 && (
                <ol class="space-y-3">
                  {section.numbered.map((item, index) => (
                    <li class="flex gap-3 rounded-2xl bg-slate-50 p-4 text-base leading-7 text-slate-700">
                      <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-950 text-xs font-bold text-white">{index + 1}</span>
                      <span data-l10n-en={item.en} data-l10n-zh={item.zh}>{getLocalizedPairText(item, pageLang)}</span>
                    </li>
                  ))}
                </ol>
              )}
            </section>
          ))}
        </div>
      </section>
    </div>

    <aside class="space-y-6 lg:sticky lg:top-24">
      <section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
        <h2 data-i18n="detail.quick" class="text-lg font-bold text-slate-950">{t['detail.quick']}</h2>
        <dl class="mt-5 space-y-4">
          {quickFacts.map((fact) => (
            <div class="rounded-2xl bg-slate-50 p-4">
              <dt data-i18n={fact.labelKey} class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">{t[fact.labelKey]}</dt>
              <dd class="mt-2 text-sm font-semibold leading-7 text-slate-900">
                {fact.valueKey ? (
                  <span data-i18n={fact.valueKey}>{t[fact.valueKey]}</span>
                ) : (
                  <span data-l10n-en={fact.en} data-l10n-zh={fact.zh}>{pageLang === 'zh' ? fact.zh : fact.en}</span>
                )}
              </dd>
            </div>
          ))}
        </dl>
      </section>

      {monetizationItems.length > 0 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
          <h2 data-i18n="detail.monetisation" class="text-lg font-bold text-slate-950">{t['detail.monetisation']}</h2>
          <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
            {monetizationItems.map((item) => (
              <li class="rounded-2xl bg-slate-50 px-4 py-3">
                <span data-l10n-en={item.en} data-l10n-zh={item.zh}>{getLocalizedPairText(item, pageLang)}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {executionSteps.length > 0 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
          <h2 data-i18n="detail.execution" class="text-lg font-bold text-slate-950">{t['detail.execution']}</h2>
          <ol class="mt-4 space-y-3">
            {executionSteps.map((item, index) => (
              <li class="flex gap-3 rounded-2xl bg-slate-50 p-4 text-sm leading-7 text-slate-600">
                <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-950 text-xs font-bold text-white">{index + 1}</span>
                <span data-l10n-en={item.en} data-l10n-zh={item.zh}>{getLocalizedPairText(item, pageLang)}</span>
              </li>
            ))}
          </ol>
        </section>
      )}

      {keywordItems.length > 0 && (
        <section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
          <h2 data-i18n="detail.keywords" class="text-lg font-bold text-slate-950">{t['detail.keywords']}</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {keywordItems.map((item) => (
              <span class="rounded-full bg-sky-50 px-3 py-2 text-xs font-semibold text-sky-700 ring-1 ring-inset ring-sky-200">{item}</span>
            ))}
          </div>
        </section>
      )}

      <section class="rounded-[28px] border border-slate-200 bg-slate-950 p-6 text-white shadow-soft">
        <p data-i18n="detail.next_label" class="text-sm font-semibold text-blue-100">{t['detail.next_label']}</p>
        <p data-i18n="detail.next_p" class="mt-3 text-lg font-semibold leading-8">{t['detail.next_p']}</p>
        <div class="mt-6 flex flex-col gap-3">
          <a href={withLangPath('/archive', pageLang)} data-lang-href="/archive" data-i18n="detail.next_btn1" class="inline-flex items-center justify-center rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-slate-100">
            {t['detail.next_btn1']}
          </a>
          <a href={withLangPath('/about', pageLang)} data-lang-href="/about" data-i18n="detail.next_btn2" class="inline-flex items-center justify-center rounded-full border border-white/15 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10">
            {t['detail.next_btn2']}
          </a>
        </div>
      </section>
    </aside>
  </article>
</Layout>
