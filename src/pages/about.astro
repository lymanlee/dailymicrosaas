---
import Layout from '../layouts/Layout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Daily Micro SaaS',
  description: 'Learn how Daily Micro SaaS picks directions, what we focus on, and what we skip.',
  url: 'https://dailymicrosaas.pages.dev/about',
};
---

<Layout title="About - Daily Micro SaaS" description="Learn how Daily Micro SaaS picks directions, what we focus on, and what we skip." structuredData={structuredData}>
  <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-sm lg:p-10">
    <span data-i18n="about.kicker" class="section-kicker">About</span>
    <h1 data-i18n="about.h1" class="mt-3 text-4xl font-black tracking-tight text-slate-950">This isn't an inspiration board. It's a decision-making tool.</h1>
    <p data-i18n="about.subhead" class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
      Daily Micro SaaS exists to answer one question: which directions are actually worth starting right now? We try to show our work.
    </p>
  </section>

  <section class="mt-8 grid gap-5 lg:grid-cols-3">
    <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <p data-i18n="about.focus.label" class="text-sm font-semibold text-slate-500">What we focus on</p>
      <h2 data-i18n="about.focus.h" class="mt-3 text-2xl font-bold text-slate-950">Real demand</h2>
      <p data-i18n="about.focus.p" class="mt-3 leading-7 text-slate-600">We only cover ideas with clear user evidence — people complaining, searching, and looking for alternatives.</p>
    </div>
    <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <p data-i18n="about.give.label" class="text-sm font-semibold text-slate-500">What we give you</p>
      <h2 data-i18n="about.give.h" class="mt-3 text-2xl font-bold text-slate-950">Execution context</h2>
      <p data-i18n="about.give.p" class="mt-3 leading-7 text-slate-600">Every direction includes competitive signals, the fastest MVP path, and a viable monetisation angle so you can make a decision fast.</p>
    </div>
    <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <p data-i18n="about.skip.label" class="text-sm font-semibold text-slate-500">What we don't do</p>
      <h2 data-i18n="about.skip.h" class="mt-3 text-2xl font-bold text-slate-950">We're not pretending to be finished</h2>
      <p data-i18n="about.skip.p" class="mt-3 leading-7 text-slate-600">Still in MVP. We're focusing on content quality and reading experience first. Subscriptions, contact forms, and smarter recommendations come later.</p>
    </div>
  </section>

  <section class="mt-8 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
      <h2 data-i18n="about.criteria.h" class="text-2xl font-bold text-slate-950">Selection criteria</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c1.h" class="font-semibold text-slate-900">Small and specific</p>
          <p data-i18n="about.criteria.c1.p" class="mt-2 text-sm leading-7 text-slate-600">Single pain point. Not a platform, not a suite — something you can describe in one sentence.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c2.h" class="font-semibold text-slate-900">Fast to build</p>
          <p data-i18n="about.criteria.c2.p" class="mt-2 text-sm leading-7 text-slate-600">Two to four weeks to a working MVP. Longer research cycles are a hard filter.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c3.h" class="font-semibold text-slate-900">Still room to compete</p>
          <p data-i18n="about.criteria.c3.p" class="mt-2 text-sm leading-7 text-slate-600">Even with existing players, there should be a clear angle — better UX, speed, positioning, or AI integration.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c4.h" class="font-semibold text-slate-900">A believable revenue model</p>
          <p data-i18n="about.criteria.c4.p" class="mt-2 text-sm leading-7 text-slate-600">Subscription, one-time purchase, an enterprise API tier, or an upsell. Traffic without a revenue story is a skip.</p>
        </div>
      </div>
    </div>

    <div class="rounded-[28px] border border-slate-200 bg-slate-950 p-8 text-white shadow-soft">
      <h2 data-i18n="about.status.h" class="text-2xl font-bold">Current status</h2>
      <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-300" id="about-status-list">
        <li data-about-status="0">• Served via the default pages.dev domain while we validate.</li>
        <li data-about-status="1">• Small catalogue, but every page is built for readability and decision-making.</li>
        <li data-about-status="2">• Custom domain, subscriptions, and automation come after the MVP is stable.</li>
      </ul>
      <div class="mt-8 rounded-3xl bg-white/10 p-5">
        <p data-i18n="about.status.cta_label" class="text-sm font-semibold text-blue-100">Next best step</p>
        <p data-i18n="about.status.cta_p" class="mt-2 text-lg font-semibold">Keep reading until you find one idea you want to start this week.</p>
        <a href="/" data-i18n="about.status.cta_btn" class="mt-4 inline-flex rounded-full bg-white px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-slate-100">
          See today's pick
        </a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // About page: handle the status list items which are an array
  document.addEventListener('langchange', function(e) {
    var t = e.detail && e.detail.t;
    if (!t) return;
    var items = t['about.status.items'];
    if (!items) return;
    items.forEach(function(text, i) {
      var el = document.querySelector('[data-about-status="' + i + '"]');
      if (el) el.textContent = '\u2022 ' + text;
    });
  });
</script>
