---
import Layout from '../layouts/Layout.astro';
import SubscribeCta from '../components/SubscribeCta.astro';
import { ui, withLangPath, type Lang } from '../lib/i18n';

const pageLang: Lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const t = ui[pageLang] ?? ui.en;
const statusItemsEn = ui.en['about.status.items'];
const statusItemsZh = ui.zh['about.status.items'];

const pageTitleMap = {
  en: 'About - Daily Micro SaaS',
  zh: '关于项目｜Daily Micro SaaS',
};
const pageDescriptionMap = {
  en: 'Learn how Daily Micro SaaS picks directions, what we focus on, and what we skip.',
  zh: '了解 Daily Micro SaaS 如何筛选方向、重点看什么，以及当前阶段暂时不做什么。',
};
const siteUrl = (Astro.site?.toString() || 'https://dailymicrosaas.pages.dev').replace(/\/$/, '');
const pageUrl = new URL(withLangPath('/about', pageLang), `${siteUrl}/`).toString();
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: pageLang === 'zh' ? '关于 Daily Micro SaaS' : 'About Daily Micro SaaS',
  description: pageDescriptionMap[pageLang],
  url: pageUrl,
  inLanguage: pageLang === 'zh' ? 'zh-CN' : 'en',
};
---

<Layout
  title={pageTitleMap[pageLang]}
  description={pageDescriptionMap[pageLang]}
  structuredData={structuredData}
  lang={pageLang}
  i18nTitle={pageTitleMap}
  i18nDescription={pageDescriptionMap}
>
  <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-sm lg:p-10">
    <span data-i18n="about.kicker" class="section-kicker">{t['about.kicker']}</span>
    <h1 data-i18n="about.h1" class="mt-3 text-4xl font-black tracking-tight text-slate-950">{t['about.h1']}</h1>
    <p data-i18n="about.subhead" class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
      {t['about.subhead']}
    </p>
  </section>

  <section class="mt-8 grid gap-5 lg:grid-cols-3">
    <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <p data-i18n="about.focus.label" class="text-sm font-semibold text-slate-500">{t['about.focus.label']}</p>
      <h2 data-i18n="about.focus.h" class="mt-3 text-2xl font-bold text-slate-950">{t['about.focus.h']}</h2>
      <p data-i18n="about.focus.p" class="mt-3 leading-7 text-slate-600">{t['about.focus.p']}</p>
    </div>
    <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <p data-i18n="about.give.label" class="text-sm font-semibold text-slate-500">{t['about.give.label']}</p>
      <h2 data-i18n="about.give.h" class="mt-3 text-2xl font-bold text-slate-950">{t['about.give.h']}</h2>
      <p data-i18n="about.give.p" class="mt-3 leading-7 text-slate-600">{t['about.give.p']}</p>
    </div>
    <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <p data-i18n="about.skip.label" class="text-sm font-semibold text-slate-500">{t['about.skip.label']}</p>
      <h2 data-i18n="about.skip.h" class="mt-3 text-2xl font-bold text-slate-950">{t['about.skip.h']}</h2>
      <p data-i18n="about.skip.p" class="mt-3 leading-7 text-slate-600">{t['about.skip.p']}</p>
    </div>
  </section>

  <section class="mt-8 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm">
      <h2 data-i18n="about.criteria.h" class="text-2xl font-bold text-slate-950">{t['about.criteria.h']}</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c1.h" class="font-semibold text-slate-900">{t['about.criteria.c1.h']}</p>
          <p data-i18n="about.criteria.c1.p" class="mt-2 text-sm leading-7 text-slate-600">{t['about.criteria.c1.p']}</p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c2.h" class="font-semibold text-slate-900">{t['about.criteria.c2.h']}</p>
          <p data-i18n="about.criteria.c2.p" class="mt-2 text-sm leading-7 text-slate-600">{t['about.criteria.c2.p']}</p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c3.h" class="font-semibold text-slate-900">{t['about.criteria.c3.h']}</p>
          <p data-i18n="about.criteria.c3.p" class="mt-2 text-sm leading-7 text-slate-600">{t['about.criteria.c3.p']}</p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-5">
          <p data-i18n="about.criteria.c4.h" class="font-semibold text-slate-900">{t['about.criteria.c4.h']}</p>
          <p data-i18n="about.criteria.c4.p" class="mt-2 text-sm leading-7 text-slate-600">{t['about.criteria.c4.p']}</p>
        </div>
      </div>
    </div>

    <div class="rounded-[28px] border border-slate-200 bg-slate-950 p-8 text-white shadow-soft">
      <h2 data-i18n="about.status.h" class="text-2xl font-bold">{t['about.status.h']}</h2>
      <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-300">
        {statusItemsEn.map((_, index) => {
          const enText = `• ${statusItemsEn[index]}`;
          const zhText = `• ${statusItemsZh[index]}`;
          return (
            <li data-l10n-en={enText} data-l10n-zh={zhText}>
              {pageLang === 'zh' ? zhText : enText}
            </li>
          );
        })}
      </ul>
      <div class="mt-8 rounded-3xl bg-white/10 p-5">
        <p data-i18n="about.status.cta_label" class="text-sm font-semibold text-blue-100">{t['about.status.cta_label']}</p>
        <p data-i18n="about.status.cta_p" class="mt-2 text-lg font-semibold">{t['about.status.cta_p']}</p>
        <a href={withLangPath('/', pageLang)} data-lang-href="/" data-i18n="about.status.cta_btn" class="mt-4 inline-flex rounded-full bg-white px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-slate-100">
          {t['about.status.cta_btn']}
        </a>
      </div>
    </div>
  </section>

  <section class="mt-8">
    <SubscribeCta />
  </section>
</Layout>
